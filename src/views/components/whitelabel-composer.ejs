<div x-data="settingsComposer()" class="max-w-4xl mx-auto bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden pb-16">
    <!-- Header -->
    <div class="px-6 py-5 border-b border-gray-200 bg-gray-50 flex justify-between items-center">
        <div>
            <h2 class="text-xl font-semibold text-gray-900">Dashboard Settings & Auto-Pilot</h2>
            <p class="text-sm text-gray-500 mt-1">Configure brand styling and automated content deployment.</p>
        </div>
        <button @click="saveSettings()" :disabled="saving" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white transition-colors"
                :class="saving ? 'bg-indigo-400 cursor-not-allowed' : 'bg-indigo-600 hover:bg-indigo-700'">
            <svg x-show="saving" class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span x-text="saving ? 'Saving...' : 'Save Settings'"></span>
        </button>
    </div>

    <div class="p-6 space-y-8">
        <!-- Automation Section -->
        <section>
            <h3 class="text-lg font-medium text-gray-900 border-b pb-2 mb-4">Automation Engine</h3>
            
            <div class="flex items-center justify-between bg-slate-50 p-4 rounded-lg border border-slate-200">
                <div class="flex-1 pr-4">
                    <h4 class="text-md font-semibold text-gray-900">Zero-Touch Auto-Pilot Mode</h4>
                    <p class="text-sm text-gray-500 mt-1">When enabled, AI-generated content automatically bypasses human approval and gets published immediately. The Radar Tracker will instantly trigger recovery posts when a ranking drop is detected.</p>
                </div>
                <!-- Alpine Toggle Switch -->
                <button type="button" 
                        class="relative inline-flex flex-shrink-0 h-6 w-11 border-2 border-transparent rounded-full cursor-pointer transition-colors ease-in-out duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" 
                        :class="autoPilotEnabled ? 'bg-indigo-600' : 'bg-gray-200'"
                        @click="autoPilotEnabled = !autoPilotEnabled">
                    <span class="sr-only">Enable Auto-Pilot</span>
                    <span class="pointer-events-none relative inline-block h-5 w-5 rounded-full bg-white shadow transform ring-0 transition ease-in-out duration-200"
                          :class="autoPilotEnabled ? 'translate-x-5' : 'translate-x-0'">
                    </span>
                </button>
            </div>
        </section>

        <!-- Mock Whitelabel Settings -->
        <section>
            <h3 class="text-lg font-medium text-gray-900 border-b pb-2 mb-4">Branding Configuration</h3>
            <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
                <div class="sm:col-span-3">
                    <label class="block text-sm font-medium text-gray-700">App Title</label>
                    <input type="text" x-model="appTitle" :disabled="saving" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm disabled:bg-gray-100 disabled:text-gray-500">
                </div>
                
                <div class="sm:col-span-3">
                    <label class="block text-sm font-medium text-gray-700">Primary Brand Color (Hex)</label>
                    <div class="mt-1 flex rounded-md shadow-sm">
                        <span class="inline-flex items-center px-3 rounded-l-md border border-r-0 border-gray-300 bg-gray-50" :style="'background-color: ' + brandPrimaryHex">
                        </span>
                        <input type="text" x-model="brandPrimaryHex" :disabled="saving" class="flex-1 block w-full border border-gray-300 rounded-none rounded-r-md py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm disabled:bg-gray-100 disabled:text-gray-500">
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>

<script>
function settingsComposer() {
    return {
        autoPilotEnabled: false,
        appTitle: 'Apex Marketing Hub',
        brandPrimaryHex: '#FF5733',
        saving: false,
        
        async saveSettings() {
            this.saving = true;
            try {
                // Simulate network latency & save
                await new Promise(r => setTimeout(r, 800));
                
                // Real-world would send a POST to /api/v1/locations/:id and /api/v1/settings/whitelabel
                console.log('Settings Saved! Auto-Pilot:', this.autoPilotEnabled);
            } catch (err) {
                console.error(err);
            } finally {
                this.saving = false;
            }
        }
    }
}
</script>
