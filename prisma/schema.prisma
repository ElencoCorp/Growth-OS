generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id                    Int                  @id @default(autoincrement())
  name                  String
  ownerId               String?
  planType              String               @default("FREE")
  subscriptionActive    Boolean              @default(false)
  subscriptionExpiresAt DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  businesses            Business[]
  locations             Location[]
  members               OrganizationMember[]
  reportSnapshots       ReportSnapshot[]
  whiteLabelSettings    String? // JSON string
  platformCredentials   PlatformCredential[]
  radarKeywords         RadarKeyword[] // Fixed: Added back-relation
}

model OrganizationMember {
  id             Int          @id @default(autoincrement())
  userId         String
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           String       @default("MEMBER")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
}

model Business {
  id             Int              @id @default(autoincrement())
  name           String
  category       String           @default("General")
  organizationId Int
  organization   Organization     @relation(fields: [organizationId], references: [id])
  locations      Location[]
  competitors    Competitor[]
  automations    AutomationRule[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Location {
  id                       Int                  @id @default(autoincrement())
  name                     String
  description              String?
  address                  String?
  phone                    String?
  website                  String?
  categories               String? // JSON string or comma-separated
  hours                    String? // JSON string
  metrics                  String? // JSON string containing performance stats
  autoPilotEnabled         Boolean              @default(false)
  businessId               Int
  business                 Business             @relation(fields: [businessId], references: [id])
  organizationId           Int?
  organization             Organization?        @relation(fields: [organizationId], references: [id])
  reviews                  Review[]
  contentPieces            ContentPiece[]
  metricSnapshots          MetricSnapshot[]
  reportSnapshots          ReportSnapshot[]
  keywords                 Keyword[]
  competitors              Competitor[]
  seoScans                 SeoGridScan[]
  googleAccessToken        String?
  googleRefreshToken       String?
  googleReviewId           String?
  lastReviewSync           DateTime?
  lastInsightsSync         DateTime?
  healthScore              Int                  @default(0)
  metaAccessToken          String?
  facebookPageId           String?
  instagramAccountId       String?
  googleVerificationStatus String               @default("UNVERIFIED")
  googlePlaceId            String?
  onboardedBatchId         String?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  radarKeywords            RadarKeyword[]
  gmbInsights              GmbInsightSnapshot[]
  keywordRankings          KeywordRanking[]
  dailyBriefings           DailyAiBriefing[]
  campaigns                Campaign[]
  approvalQueue            ApprovalItem[]
}

model MetricSnapshot {
  id            Int      @id @default(autoincrement())
  locationId    Int
  location      Location @relation(fields: [locationId], references: [id])
  date          DateTime
  profileViews  Int
  searchQueries Int
  interactions  Int
  createdAt     DateTime @default(now())

  @@index([locationId, date])
}

model ReportSnapshot {
  id             Int          @id @default(autoincrement())
  locationId     Int
  location       Location     @relation(fields: [locationId], references: [id])
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  generatedAt    DateTime     @default(now())
  dateRange      String
  reportData     String // JSON string containing metrics and AI summary
  status         String       @default("DRAFT")
}

model Keyword {
  id               Int               @id @default(autoincrement())
  locationId       Int
  location         Location          @relation(fields: [locationId], references: [id])
  term             String
  lat              Float?
  lng              Float?
  rankingSnapshots RankingSnapshot[]
  createdAt        DateTime          @default(now())
}

model RankingSnapshot {
  id             Int      @id @default(autoincrement())
  keywordId      Int
  keyword        Keyword  @relation(fields: [keywordId], references: [id])
  date           DateTime
  rank           Int
  topCompetitors String
  createdAt      DateTime @default(now())

  @@index([keywordId, date])
}

model Review {
  id               Int            @id @default(autoincrement())
  authorName       String
  authorPhotoUrl   String?
  rating           Int
  text             String
  sentimentScore   Float?
  status           String         @default("NEEDS_REPLY") // NEEDS_REPLY, REPLIED, SPAM, ARCHIVED
  reply            String?
  googleReviewId   String         @unique
  locationId       Int
  location         Location       @relation(fields: [locationId], references: [id])
  aiSuggestedReply String?
  publishedReply   String?
  replyPublishedAt DateTime?
  createdAt        DateTime       @default(now())
  approvalItems    ApprovalItem[]
}

model Competitor {
  id             Int       @id @default(autoincrement())
  name           String
  googlePlaceId  String?
  reviewCount    Int
  averageRating  Float
  currentRank    Int       @default(0)
  postingFreq    Int // Posts per month
  aiStrategyText String?
  lastAudited    DateTime  @default(now())
  locationId     Int?
  location       Location? @relation(fields: [locationId], references: [id])
  businessId     Int?
  business       Business? @relation(fields: [businessId], references: [id])
}

model User {
  id                 Int           @id @default(autoincrement())
  email              String        @unique
  passwordHash       String?
  role               String        @default("Client") // "Administrator" or "Client"
  googleId           String?       @unique
  googleAccessToken  String?
  googleRefreshToken String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  AiActionLog        AiActionLog[]
}

model SeoGridScan {
  id           Int           @id @default(autoincrement())
  locationId   Int
  location     Location      @relation(fields: [locationId], references: [id])
  keyword      String
  centerLat    Float
  centerLng    Float
  radiusMeters Int           @default(1000)
  gridSize     Int           @default(3)
  status       String        @default("Pending")
  nodes        SeoGridNode[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model SeoGridNode {
  id        Int         @id @default(autoincrement())
  scanId    Int
  scan      SeoGridScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  rank      Int?
  placeId   String?
  createdAt DateTime    @default(now())
}

model PlatformCredential {
  id             Int             @id @default(autoincrement())
  organizationId Int
  organization   Organization    @relation(fields: [organizationId], references: [id])
  platform       String // e.g., "GBP", "META", "X"
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  publishTargets PublishTarget[]
}

model PublishTarget {
  id                   Int                  @id @default(autoincrement())
  platformCredentialId Int
  platformCredential   PlatformCredential   @relation(fields: [platformCredentialId], references: [id])
  platformAccountId    String // The external ID of the page/location on the platform
  contentPieces        ContentPieceTarget[]
}

model ContentPiece {
  id           Int                  @id @default(autoincrement())
  locationId   Int
  location     Location             @relation(fields: [locationId], references: [id])
  textContent  String
  imageUrl     String?
  status       String               @default("DRAFT_PENDING_REVIEW") // Transitions: -> APPROVED -> QUEUED -> PUBLISHED
  scheduledFor DateTime?
  targets      ContentPieceTarget[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  ApprovalItem ApprovalItem[]
}

model ContentPieceTarget {
  id              Int           @id @default(autoincrement())
  contentPieceId  Int
  contentPiece    ContentPiece  @relation(fields: [contentPieceId], references: [id], onDelete: Cascade)
  publishTargetId Int
  publishTarget   PublishTarget @relation(fields: [publishTargetId], references: [id], onDelete: Cascade)
  status          String        @default("PENDING") // "PENDING", "PUBLISHED", "FAILED"
  externalPostId  String?
  errorMessage    String?
  publishedAt     DateTime?

  @@unique([contentPieceId, publishTargetId])
}

model RadarKeyword {
  id             String         @id @default(uuid())
  locationId     Int // Fixed: Changed from String to Int to match Location.id
  location       Location       @relation(fields: [locationId], references: [id])
  organizationId Int // Fixed: Changed from String to Int to match Organization.id
  organization   Organization   @relation(fields: [organizationId], references: [id])
  keywordText    String // e.g., "Dentist in Ravet"
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  rankHistories  RadarHistory[]

  @@index([locationId])
  @@index([organizationId])
}

model RadarHistory {
  id            String       @id @default(uuid())
  keywordId     String
  keyword       RadarKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  rankPlacement Int // Map-Pack rank position (e.g., 1-20, or 0 for unranked)
  competitorMap String // Stringified JSON tracking top competitors and their positions
  capturedAt    DateTime     @default(now())

  @@index([keywordId])
  @@index([capturedAt])
}

model CronJob {
  id        String       @id @default(uuid())
  jobName   String       @unique // e.g., "WEEKLY_RADAR_SCAN", "DAILY_REVIEW_SYNC", "BATCH_POST_PUBLISH"
  status    String       @default("IDLE") // "IDLE", "RUNNING", "FAILED"
  lastRunAt DateTime?
  nextRunAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  logs      CronJobLog[]
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId Int
  userId         String? // The user actor executing the transaction
  action         String // e.g., "BULK_IMPORT_EXECUTE", "OAUTH_TOKEN_REFRESH", "SUBSCRIPTION_GATE_BYPASS"
  entityType     String // e.g., "Location", "PlatformCredential", "Organization"
  entityId       String? // ID tracking the mutated resource
  metadata       String? // Stringified JSON capturing old vs new payload data changes
  ipAddress      String?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([action])
  @@index([createdAt])
}

model CronJobLog {
  id          String   @id @default(uuid())
  cronJobId   String
  cronJob     CronJob  @relation(fields: [cronJobId], references: [id], onDelete: Cascade)
  status      String // "COMPLETED", "FAILED", "WARNING"
  message     String? // Stack trace summary or performance metadata
  durationMs  Int
  recordsSent Int      @default(0)
  executedAt  DateTime @default(now())

  @@index([cronJobId])
  @@index([executedAt])
}

// ═══════════════════════════════════════════════════════════════
// NEW DOMAIN MODELS — Platform Core Compilation Engine v2
// ═══════════════════════════════════════════════════════════════

model GmbInsightSnapshot {
  id            Int      @id @default(autoincrement())
  locationId    Int
  views         Int      @default(0)
  searches      Int      @default(0)
  calls         Int      @default(0)
  directions    Int      @default(0)
  websiteClicks Int      @default(0)
  bookings      Int      @default(0)
  messages      Int      @default(0)
  photosViewed  Int      @default(0)
  capturedDate  DateTime @default(now())
  location      Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model KeywordRanking {
  id           Int      @id @default(autoincrement())
  locationId   Int
  keyword      String
  currentRank  Int
  previousRank Int
  lastScanned  DateTime @default(now())
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model Campaign {
  id           Int      @id @default(autoincrement())
  locationId   Int
  campaignType String // REVIEW, POSTING, SEO, COMPETITOR
  status       String   @default("ACTIVE") // ACTIVE, COMPLETED, PAUSED
  planPayload  String // Stringified JSON of generated milestones
  createdAt    DateTime @default(now())
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model DailyAiBriefing {
  id               Int      @id @default(autoincrement())
  locationId       Int
  briefingText     String
  opportunityText  String?
  forecastScore7d  Int      @default(80)
  forecastScore30d Int      @default(80)
  forecastScore90d Int      @default(80)
  createdAt        DateTime @default(now())
  location         Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model AutomationRule {
  id            Int      @id @default(autoincrement())
  businessId    Int
  ruleType      String // REVIEW_AUTO_REPLY, DAILY_POST_GENERATOR, PHOTO_REMINDER
  isActive      Boolean  @default(true)
  configPayload String // Stringified JSON operational preferences
  createdAt     DateTime @default(now())
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ApprovalItem {
  id               Int           @id @default(autoincrement())
  locationId       Int
  itemType         String // REVIEW_REPLY, POST_PUBLISH
  reviewId         Int?
  contentPieceId   Int?
  generatedPayload String // Text parameters waiting for deployment
  status           String        @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt        DateTime      @default(now())
  location         Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  review           Review?       @relation(fields: [reviewId], references: [id])
  contentTarget    ContentPiece? @relation(fields: [contentPieceId], references: [id])
}

model AiActionLog {
  id            Int      @id @default(autoincrement())
  userId        Int
  actionType    String
  promptPayload String
  responseBody  String
  tokenCost     Int      @default(0)
  executionTime Int      @default(0)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
