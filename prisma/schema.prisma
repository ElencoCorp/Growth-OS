generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id                    Int                  @id @default(autoincrement())
  name                  String
  ownerId               String?
  planType              String               @default("FREE")
  subscriptionActive    Boolean              @default(false)
  subscriptionExpiresAt DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  businesses            Business[]
  locations             Location[]
  members               OrganizationMember[]
  reportSnapshots       ReportSnapshot[]
  whiteLabelSettings    String? // JSON string
}

model OrganizationMember {
  id             Int          @id @default(autoincrement())
  userId         String
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           String       @default("MEMBER")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
}

model Business {
  id             Int          @id @default(autoincrement())
  name           String
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  locations      Location[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Location {
  id                       Int              @id @default(autoincrement())
  name                     String
  description              String?
  address                  String?
  phone                    String?
  website                  String?
  categories               String? // JSON string or comma-separated
  hours                    String? // JSON string
  metrics                  String? // JSON string containing performance stats
  businessId               Int
  business                 Business         @relation(fields: [businessId], references: [id])
  organizationId           Int?
  organization             Organization?    @relation(fields: [organizationId], references: [id])
  reviews                  Review[]
  posts                    Post[]
  localPosts               LocalPost[]
  metricSnapshots          MetricSnapshot[]
  reportSnapshots          ReportSnapshot[]
  keywords                 Keyword[]
  competitors              Competitor[]
  seoScans                 SeoGridScan[]
  googleAccessToken        String?
  googleRefreshToken       String?
  googleReviewId           String?
  lastReviewSync           DateTime?
  lastInsightsSync         DateTime?
  healthScore              Int              @default(0)
  metaAccessToken          String?
  facebookPageId           String?
  instagramAccountId       String?
  googleVerificationStatus String           @default("UNVERIFIED")
  googlePlaceId            String?
  onboardedBatchId         String?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
}

model MetricSnapshot {
  id            Int      @id @default(autoincrement())
  locationId    Int
  location      Location @relation(fields: [locationId], references: [id])
  date          DateTime
  profileViews  Int
  searchQueries Int
  interactions  Int
  createdAt     DateTime @default(now())

  @@index([locationId, date])
}

model ReportSnapshot {
  id             Int          @id @default(autoincrement())
  locationId     Int
  location       Location     @relation(fields: [locationId], references: [id])
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  generatedAt    DateTime     @default(now())
  dateRange      String
  reportData     String // JSON string containing metrics and AI summary
  status         String       @default("DRAFT")
}

model Keyword {
  id               Int               @id @default(autoincrement())
  locationId       Int
  location         Location          @relation(fields: [locationId], references: [id])
  term             String
  lat              Float?
  lng              Float?
  rankingSnapshots RankingSnapshot[]
  createdAt        DateTime          @default(now())
}

model RankingSnapshot {
  id             Int      @id @default(autoincrement())
  keywordId      Int
  keyword        Keyword  @relation(fields: [keywordId], references: [id])
  date           DateTime
  rank           Int
  topCompetitors String
  createdAt      DateTime @default(now())

  @@index([keywordId, date])
}

model Review {
  id               Int       @id @default(autoincrement())
  authorName       String
  rating           Int
  text             String
  reply            String?
  googleReviewId   String    @unique
  locationId       Int
  location         Location  @relation(fields: [locationId], references: [id])
  aiSuggestedReply String?
  publishedReply   String?
  replyPublishedAt DateTime?
  createdAt        DateTime  @default(now())
}

model Post {
  id           Int       @id @default(autoincrement())
  textContent  String
  imageUrl     String?
  status       String    @default("DRAFT")
  googlePostId String?   @unique
  scheduledFor DateTime?
  channels     String    @default("[\"GBP\"]")
  errorMessage String?
  publishedAt  DateTime?
  locationId   Int
  location     Location  @relation(fields: [locationId], references: [id])
  createdAt    DateTime  @default(now())
}

model Competitor {
  id            Int      @id @default(autoincrement())
  name          String
  reviewCount   Int
  averageRating Float
  postingFreq   Int // Posts per month
  locationId    Int
  location      Location @relation(fields: [locationId], references: [id])
}

model User {
  id                 Int      @id @default(autoincrement())
  email              String   @unique
  passwordHash       String?
  role               String   @default("Client") // "Administrator" or "Client"
  googleId           String?  @unique
  googleAccessToken  String?
  googleRefreshToken String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SeoGridScan {
  id           Int           @id @default(autoincrement())
  locationId   Int
  location     Location      @relation(fields: [locationId], references: [id])
  keyword      String
  centerLat    Float
  centerLng    Float
  radiusMeters Int           @default(1000)
  gridSize     Int           @default(3)
  status       String        @default("Pending")
  nodes        SeoGridNode[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model SeoGridNode {
  id        Int         @id @default(autoincrement())
  scanId    Int
  scan      SeoGridScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  rank      Int?
  placeId   String?
  createdAt DateTime    @default(now())
}

model LocalPost {
  id           Int       @id @default(autoincrement())
  locationId   Int
  location     Location  @relation(fields: [locationId], references: [id])
  textContent  String
  imageUrl     String?
  status       String    @default("DRAFT")
  googlePostId String?   @unique
  scheduledFor DateTime?
  publishedAt  DateTime?
  channels     String    @default("[\"GBP\"]")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model RadarKeyword {
  id             String         @id @default(uuid())
  locationId     String
  organizationId String
  keywordText    String // e.g., "Dentist in Ravet"
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  rankHistories  RadarHistory[]

  @@index([locationId])
  @@index([organizationId])
}

model RadarHistory {
  id            String       @id @default(uuid())
  keywordId     String
  keyword       RadarKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  rankPlacement Int // Map-Pack rank position (e.g., 1-20, or 0 for unranked)
  competitorMap String // Stringified JSON tracking top competitors and their positions
  capturedAt    DateTime     @default(now())

  @@index([keywordId])
  @@index([capturedAt])
}
