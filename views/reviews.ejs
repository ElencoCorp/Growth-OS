<div class="max-w-[1440px] mx-auto px-6 lg:px-8 py-8" id="main-content">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Reputation Dashboard</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Monitor and respond to customer reviews across your locations.</p>
    </div>

    <div class="grid grid-cols-1 gap-4">
        <% if (reviews && reviews.length > 0) { %>
            <% reviews.forEach(function(review) { %>
                <div class="bg-white dark:bg-[#111827] rounded-xl border border-slate-200/80 dark:border-[#1F2937] p-6 shadow-sm">
                    <div class="flex justify-between items-start mb-3">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-slate-100 dark:bg-slate-800 rounded-full flex items-center justify-center text-lg font-bold text-slate-600 dark:text-slate-300">
                                <%= review.authorName ? review.authorName.charAt(0).toUpperCase() : 'U' %>
                            </div>
                            <div>
                                <h4 class="text-sm font-bold text-slate-900 dark:text-white"><%= review.authorName %></h4>
                                <div class="flex text-amber-400 text-sm mt-0.5">
                                    <% for(let i=0; i<review.rating; i++) { %>★<% } %>
                                </div>
                            </div>
                        </div>
                        <span class="text-xs font-medium text-slate-500"><%= new Date(review.createdAt).toLocaleDateString() %></span>
                    </div>
                    <p class="text-sm text-slate-700 dark:text-slate-300 mb-4"><%= review.text || 'No comment provided.' %></p>
                    
                    <div class="border-t border-slate-100 dark:border-[#1F2937] pt-4 flex justify-between items-center">
                        <span class="inline-flex items-center px-2 py-1 rounded text-[10px] font-bold tracking-wider uppercase <%= review.status === 'REPLIED' ? 'bg-emerald-50 text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400' : 'bg-rose-50 text-rose-600 dark:bg-rose-500/10 dark:text-rose-400' %>">
                            <%= review.status %>
                        </span>
                        <% if (review.status === 'NEEDS_REPLY') { %>
                            <button class="text-xs font-semibold bg-purple-50 text-purple-600 dark:bg-purple-500/10 dark:text-purple-400 px-3 py-1.5 rounded-lg hover:bg-purple-100 dark:hover:bg-purple-500/20 transition-colors">Generate AI Reply</button>
                        <% } else { %>
                            <button class="text-xs font-semibold text-slate-500 hover:text-slate-700 dark:hover:text-slate-300">View Reply</button>
                        <% } %>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="py-12 text-center bg-slate-50 dark:bg-[#1F2937]/30 rounded-2xl border border-dashed border-slate-300 dark:border-slate-700">
                <p class="text-slate-500 dark:text-slate-400 font-medium">No reviews found for this location.</p>
            </div>
        <% } %>
    </div>
</div>
