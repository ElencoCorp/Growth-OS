<div class="max-w-[1440px] mx-auto px-6 lg:px-8 py-8" id="main-content" x-data="reviewsInbox()">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Extended Reviews Hub</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Filter, manage, and respond to your historical review inbox.</p>
    </div>

    <!-- Top Row: Interactive Filter Tabs -->
    <div class="flex items-center gap-2 mb-6 overflow-x-auto pb-2 scrollbar-hide">
        <template x-for="tab in ['All', 'Positive', 'Negative', 'Needs Reply', 'Pending Approval']">
            <button 
                @click="setFilter(tab)"
                :class="activeFilter === tab 
                    ? 'bg-slate-900 text-white dark:bg-white dark:text-slate-900' 
                    : 'bg-white text-slate-600 border border-slate-200 hover:bg-slate-50 dark:bg-[#111827] dark:text-slate-300 dark:border-slate-700 dark:hover:bg-[#1F2937]'"
                class="px-4 py-2 rounded-full text-sm font-semibold whitespace-nowrap transition-all shadow-sm"
                x-text="tab">
            </button>
        </template>
    </div>

    <!-- Main Grid: Threaded Inbox -->
    <div class="grid grid-cols-1 gap-4 relative min-h-[300px]">
        <!-- Loading State -->
        <div x-show="isLoading" class="absolute inset-0 bg-slate-50/50 dark:bg-[#111827]/50 backdrop-blur-sm flex items-center justify-center z-10 rounded-2xl">
            <div class="w-10 h-10 border-4 border-blue-500 rounded-full border-t-transparent animate-spin"></div>
        </div>

        <!-- Empty State -->
        <div x-show="!isLoading && filteredReviews.length === 0" class="py-16 text-center bg-white dark:bg-[#111827] rounded-2xl border border-dashed border-slate-300 dark:border-slate-700">
            <div class="w-16 h-16 bg-slate-50 dark:bg-slate-800/50 text-slate-400 rounded-full mx-auto flex items-center justify-center mb-4">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
            </div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-1">No Reviews Found</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400">Try adjusting your filters or checking a different location.</p>
        </div>

        <!-- Review Cards -->
        <template x-for="review in filteredReviews" :key="review.id">
            <div class="bg-white dark:bg-[#111827] rounded-xl border border-slate-200/80 dark:border-[#1F2937] p-6 shadow-sm">
                <div class="flex justify-between items-start mb-3">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-blue-50 dark:bg-blue-500/10 rounded-full flex items-center justify-center text-lg font-bold text-blue-600 dark:text-blue-400" x-text="review.authorName ? review.authorName.charAt(0).toUpperCase() : 'U'"></div>
                        <div>
                            <h4 class="text-sm font-bold text-slate-900 dark:text-white" x-text="review.authorName"></h4>
                            <div class="flex text-amber-400 text-sm mt-0.5">
                                <template x-for="i in review.rating">
                                    <span>★</span>
                                </template>
                                <template x-for="i in (5 - review.rating)">
                                    <span class="text-slate-200 dark:text-slate-700">★</span>
                                </template>
                            </div>
                        </div>
                    </div>
                    <span class="text-xs font-medium text-slate-500" x-text="new Date(review.createdAt).toLocaleDateString()"></span>
                </div>
                <p class="text-sm text-slate-700 dark:text-slate-300 mb-4" x-text="review.text || 'No comment provided.'"></p>
                
                <!-- Status & Simple Actions -->
                <div class="border-t border-slate-100 dark:border-[#1F2937] pt-4 flex justify-between items-center" x-show="!review.aiSuggestedReply && !review.publishedReply">
                    <span class="inline-flex items-center px-2 py-1 rounded text-[10px] font-bold tracking-wider uppercase bg-rose-50 text-rose-600 dark:bg-rose-500/10 dark:text-rose-400" x-text="review.status"></span>
                    <button class="text-xs font-semibold bg-purple-50 text-purple-600 dark:bg-purple-500/10 dark:text-purple-400 px-3 py-1.5 rounded-lg hover:bg-purple-100 dark:hover:bg-purple-500/20 transition-colors">Generate AI Reply</button>
                </div>
                
                <!-- Published Reply -->
                <div class="mt-4 bg-emerald-50/50 dark:bg-emerald-500/5 rounded-xl p-4 border border-emerald-100 dark:border-emerald-500/10" x-show="review.publishedReply">
                    <div class="flex items-center gap-2 mb-2">
                        <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-xs font-bold text-emerald-700 dark:text-emerald-400 uppercase tracking-wide">Published Reply</span>
                    </div>
                    <p class="text-sm text-emerald-800 dark:text-emerald-200/80" x-text="review.publishedReply"></p>
                </div>

                <!-- AI Drafted Reply Inbox block -->
                <div class="mt-4 bg-blue-50/50 dark:bg-blue-500/5 rounded-xl p-4 border border-blue-100 dark:border-blue-500/10" x-show="review.aiSuggestedReply && !review.publishedReply">
                    <div class="flex items-center gap-2 mb-2">
                        <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        <span class="text-xs font-bold text-blue-700 dark:text-blue-400 uppercase tracking-wide">AI Drafted Reply</span>
                    </div>
                    
                    <textarea 
                        x-model="review.aiSuggestedReply" 
                        class="w-full bg-white dark:bg-[#1F2937]/50 border border-slate-200 dark:border-slate-700 rounded-lg p-3 text-sm text-slate-800 dark:text-slate-200 focus:ring-2 focus:ring-blue-500/20 outline-none transition-all mb-3 resize-none" 
                        rows="3">
                    </textarea>
                    
                    <div class="flex flex-wrap items-center gap-2">
                        <button 
                            @click="executeAction(review, 'edit', review.aiSuggestedReply)" 
                            class="px-3 py-1.5 text-xs font-semibold bg-white dark:bg-[#111827] border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 rounded-lg hover:bg-slate-50 transition-colors shadow-sm">
                            Edit Draft
                        </button>
                        <button 
                            @click="executeAction(review, 'approve', review.aiSuggestedReply)" 
                            class="px-3 py-1.5 text-xs font-semibold bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-500/20 transition-colors">
                            Approve Response
                        </button>
                        <button 
                            @click="executeAction(review, 'publish', review.aiSuggestedReply)" 
                            class="px-3 py-1.5 text-xs font-semibold bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors shadow-sm">
                            Publish Live
                        </button>
                    </div>
                </div>

            </div>
        </template>
    </div>
</div>

<script>
function reviewsInbox() {
    return {
        activeFilter: 'All',
        filteredReviews: [],
        isLoading: false,

        init() {
            // Re-fetch when active location changes in parent
            this.$watch('activeLocation', () => {
                this.fetchReviews();
            });
            // Initial fetch
            if (this.activeLocation && this.activeLocation.id) {
                this.fetchReviews();
            }
        },

        async setFilter(tab) {
            this.activeFilter = tab;
            await this.fetchReviews();
        },

        async fetchReviews() {
            if (!this.activeLocation || !this.activeLocation.id) return;
            this.isLoading = true;
            try {
                const response = await fetch(`/api/v1/reviews?locationId=${this.activeLocation.id}&filter=${encodeURIComponent(this.activeFilter)}`);
                const data = await response.json();
                if (data.success) {
                    this.filteredReviews = data.reviews;
                }
            } catch (error) {
                console.error("Failed to fetch reviews:", error);
            } finally {
                setTimeout(() => this.isLoading = false, 300); // Smooth UX
            }
        },

        async executeAction(review, action, text) {
            try {
                review.status = "UPDATING..."; // Optimistic UI
                
                const response = await fetch(`/api/v1/reviews/${review.id}/action`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: action, replyText: text })
                });
                const data = await response.json();
                
                if (data.success) {
                    // Update the local object with returned data
                    Object.assign(review, data.review);
                } else {
                    alert('Action failed: ' + data.error);
                    this.fetchReviews(); // Revert on fail
                }
            } catch (error) {
                console.error("Failed to execute action:", error);
                alert("Network error.");
                this.fetchReviews(); // Revert on fail
            }
        }
    }
}
</script>
