<div class="max-w-[1440px] mx-auto px-6 lg:px-8 py-8" id="main-content" x-data="competitorsHub()">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Competitor Watch Radar</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Analyze local market rivals and deploy AI-driven counter-strategies.</p>
    </div>

    <!-- Loading State -->
    <div x-show="isLoading" class="w-full h-[400px] flex flex-col items-center justify-center">
        <div class="w-10 h-10 border-4 border-blue-500 rounded-full border-t-transparent animate-spin mb-4"></div>
        <p class="text-sm font-semibold text-slate-500 animate-pulse">Scanning local market landscape...</p>
    </div>

    <div x-show="!isLoading" style="display: none;">
        
        <!-- Top Section: Head-to-Head Comparison -->
        <div class="bg-gradient-to-br from-slate-900 to-slate-800 dark:from-black dark:to-slate-900 rounded-3xl p-8 mb-8 shadow-xl relative overflow-hidden" x-show="competitors.length > 0">
            <!-- Background Decoration -->
            <div class="absolute -right-20 -top-20 w-64 h-64 bg-blue-500/20 blur-3xl rounded-full pointer-events-none"></div>
            
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-xl font-bold text-white tracking-tight">Market Leader Matchup</h2>
                <!-- Opportunity Score Badge -->
                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-emerald-500/20 text-emerald-400 rounded-full text-xs font-bold tracking-wide border border-emerald-500/20 shadow-sm backdrop-blur-md">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                    Opportunity Score: 78% Easy Win
                </span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 relative z-10">
                
                <!-- Target Rival Card -->
                <div class="bg-white/10 backdrop-blur-md border border-white/10 p-6 rounded-2xl flex flex-col">
                    <div class="flex justify-between items-start mb-4">
                        <span class="text-[10px] font-bold text-white/50 uppercase tracking-widest">Market Target</span>
                        <span class="text-xl font-black text-white" x-text="competitors[0]?.name"></span>
                    </div>
                    <div class="grid grid-cols-2 gap-4 mt-auto">
                        <div>
                            <p class="text-xs text-white/50 mb-1">Rating & Reviews</p>
                            <p class="text-lg font-bold text-amber-400" x-text="competitors[0]?.averageRating + ' ★'"></p>
                            <p class="text-sm font-semibold text-white/70" x-text="competitors[0]?.reviewCount + ' Total'"></p>
                        </div>
                        <div>
                            <p class="text-xs text-white/50 mb-1">Content Velocity</p>
                            <p class="text-lg font-bold text-blue-400" x-text="competitors[0]?.photoCount + ' Photos'"></p>
                            <p class="text-sm font-semibold text-white/70" x-text="competitors[0]?.postingFreq + ' Posts/mo'"></p>
                        </div>
                    </div>
                </div>
                
                <!-- VS Separator (Hidden on mobile) -->
                <div class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 bg-slate-900 border-4 border-slate-800 rounded-full items-center justify-center z-20 shadow-2xl">
                    <span class="text-sm font-black text-white/50 italic">VS</span>
                </div>

                <!-- User Card -->
                <div class="bg-blue-600/20 backdrop-blur-md border border-blue-500/30 p-6 rounded-2xl flex flex-col relative overflow-hidden">
                    <!-- Subtle highlight -->
                    <div class="absolute inset-0 bg-gradient-to-tr from-blue-600/10 to-transparent pointer-events-none"></div>
                    <div class="flex justify-between items-start mb-4 relative z-10">
                        <span class="text-[10px] font-bold text-blue-300/70 uppercase tracking-widest">Your Profile</span>
                        <span class="text-xl font-black text-white" x-text="userMetrics.name"></span>
                    </div>
                    <div class="grid grid-cols-2 gap-4 mt-auto relative z-10">
                        <div>
                            <p class="text-xs text-blue-200/50 mb-1">Rating & Reviews</p>
                            <p class="text-lg font-bold text-amber-400" x-text="userMetrics.averageRating + ' ★'"></p>
                            <p class="text-sm font-semibold text-blue-100/70" x-text="userMetrics.reviewCount + ' Total'"></p>
                        </div>
                        <div>
                            <p class="text-xs text-blue-200/50 mb-1">Content Velocity</p>
                            <p class="text-lg font-bold text-blue-400" x-text="userMetrics.photoCount + ' Photos'"></p>
                            <p class="text-sm font-semibold text-blue-100/70" x-text="userMetrics.postingFreq + ' Posts/mo'"></p>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- Empty State -->
        <div x-show="competitors.length === 0" class="py-16 text-center bg-white dark:bg-[#111827] rounded-2xl border border-dashed border-slate-300 dark:border-slate-700">
            <div class="w-16 h-16 bg-slate-50 dark:bg-slate-800/50 text-slate-400 rounded-full mx-auto flex items-center justify-center mb-4">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            </div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-1">No Competitors Tracked</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-6">Add rivals in your Local SEO settings to begin tracking head-to-head metrics.</p>
            <button class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-6 rounded-xl transition-colors">Configure Rivals</button>
        </div>

        <!-- Bottom Section: Matrices Loop -->
        <div class="grid grid-cols-1 gap-6" x-show="competitors.length > 0">
            <template x-for="competitor in competitors" :key="competitor.id">
                <div class="bg-white dark:bg-[#111827] rounded-2xl border border-slate-200/80 dark:border-[#1F2937] overflow-hidden shadow-sm flex flex-col">
                    
                    <!-- Top Bar of Card -->
                    <div class="p-6 border-b border-slate-100 dark:border-slate-800 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center text-xl font-black text-slate-400">
                                <span x-text="competitor.currentRank > 0 ? '#' + competitor.currentRank : '-'"></span>
                            </div>
                            <div>
                                <h3 class="text-lg font-bold text-slate-900 dark:text-white" x-text="competitor.name"></h3>
                                <div class="flex items-center gap-3 text-sm mt-1">
                                    <span class="inline-flex items-center gap-1 font-bold text-amber-500"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg> <span x-text="competitor.averageRating"></span></span>
                                    <span class="text-slate-500 dark:text-slate-400 font-medium" x-text="competitor.reviewCount + ' Reviews'"></span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="flex items-center gap-3">
                            <div class="text-right hidden sm:block">
                                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-0.5">Content Pace</p>
                                <p class="text-sm font-semibold text-slate-700 dark:text-slate-300" x-text="competitor.postingFreq + ' Posts/mo'"></p>
                            </div>
                            <!-- Generate Strategy Button -->
                            <button 
                                @click="generateStrategy(competitor)"
                                :disabled="competitor.isGenerating"
                                class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed text-white text-sm font-bold py-2.5 px-5 rounded-xl transition-colors shadow-sm ml-4">
                                
                                <!-- Loading Spinner -->
                                <svg x-show="competitor.isGenerating" class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                </svg>
                                
                                <svg x-show="!competitor.isGenerating" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                                <span x-text="competitor.aiStrategyText ? 'Refresh Strategy' : 'Generate Strategy'"></span>
                            </button>
                        </div>
                    </div>
                    
                    <!-- Dynamic AI Strategy Canvas -->
                    <div x-show="competitor.aiStrategyText" 
                         x-transition:enter="transition ease-out duration-300"
                         x-transition:enter-start="opacity-0 translate-y-4"
                         x-transition:enter-end="opacity-100 translate-y-0"
                         class="p-6 bg-blue-50/50 dark:bg-blue-500/5" style="display: none;">
                        
                        <div class="flex items-center gap-2 mb-4 text-blue-700 dark:text-blue-400">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                            <h4 class="text-sm font-bold uppercase tracking-wider">AI Action Plan</h4>
                        </div>
                        
                        <div class="prose prose-sm dark:prose-invert prose-blue max-w-none">
                            <!-- Format text with markdown-style line breaks if needed, or simply render pre-formatted -->
                            <div class="whitespace-pre-wrap text-slate-700 dark:text-slate-300 font-medium leading-relaxed bg-white dark:bg-[#111827] border border-blue-100 dark:border-blue-900/30 p-5 rounded-xl shadow-sm" x-text="competitor.aiStrategyText"></div>
                        </div>
                        
                        <div class="mt-4 flex gap-3">
                            <button class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold py-2 px-4 rounded-lg transition-colors">Apply Recommended Post</button>
                            <button class="bg-white dark:bg-[#1F2937] border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 text-xs font-bold py-2 px-4 rounded-lg transition-colors">Start Review Campaign</button>
                        </div>
                    </div>
                </div>
            </template>
        </div>
    </div>
</div>

<script>
function competitorsHub() {
    return {
        competitors: [],
        userMetrics: { name: 'You', averageRating: 0, reviewCount: 0, postingFreq: 0, photoCount: 0 },
        isLoading: true,

        init() {
            this.$watch('activeLocation', () => {
                this.fetchCompetitors();
            });
            
            if (this.activeLocation && this.activeLocation.id) {
                this.fetchCompetitors();
            }
        },

        async fetchCompetitors() {
            if (!this.activeLocation || !this.activeLocation.id) return;
            this.isLoading = true;
            try {
                const response = await fetch(`/api/v1/competitors?locationId=${this.activeLocation.id}`);
                const data = await response.json();
                if (data.success) {
                    this.userMetrics = data.userMetrics;
                    // Inject local UI state property
                    this.competitors = data.competitors.map(c => ({...c, isGenerating: false}));
                }
            } catch (error) {
                console.error("Failed to fetch competitors data:", error);
            } finally {
                setTimeout(() => this.isLoading = false, 400);
            }
        },
        
        async generateStrategy(competitor) {
            competitor.isGenerating = true;
            try {
                const response = await fetch(`/api/v1/competitors/${competitor.id}/generate-strategy`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({})
                });
                const data = await response.json();
                
                if (data.success) {
                    competitor.aiStrategyText = data.aiStrategyText;
                } else {
                    alert('Strategy generation failed: ' + data.error);
                }
            } catch (error) {
                console.error("Failed to execute strategy generator:", error);
                alert("Network error.");
            } finally {
                competitor.isGenerating = false;
            }
        }
    }
}
</script>
