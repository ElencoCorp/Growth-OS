<div class="max-w-[1440px] mx-auto px-6 lg:px-8 py-8" id="main-content">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Profile Settings</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Manage global preferences and OAuth integrations.</p>
    </div>

    <div class="bg-white dark:bg-[#111827] rounded-3xl border border-slate-200/80 dark:border-[#1F2937] p-8 shadow-sm max-w-3xl">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-6">Connected Integrations</h2>
        
        <div class="flex items-center justify-between p-4 bg-slate-50 dark:bg-[#1F2937]/50 rounded-xl border border-slate-100 dark:border-[#1F2937] mb-4">
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-white rounded-lg shadow-sm flex items-center justify-center p-2">
                    <svg viewBox="0 0 24 24" class="w-full h-full"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                </div>
                <div>
                    <h3 class="text-sm font-bold text-slate-900 dark:text-white">Google Business Profile</h3>
                    <p class="text-xs text-slate-500">Connected to <strong><%= organization ? organization.name : 'Unknown' %></strong></p>
                </div>
            </div>
            <button class="text-sm font-semibold text-rose-600 dark:text-rose-400 hover:text-rose-700 dark:hover:text-rose-300">Disconnect</button>
        </div>

        <div class="mt-8 border-t border-slate-100 dark:border-[#1F2937] pt-8">
            <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-6">Danger Zone</h2>
            <button class="bg-rose-50 hover:bg-rose-100 text-rose-600 dark:bg-rose-500/10 dark:hover:bg-rose-500/20 dark:text-rose-400 font-semibold py-2.5 px-6 rounded-xl transition-all">Clear Database State</button>
        </div>
    </div>
</div>
