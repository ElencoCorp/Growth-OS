                        <button @click="reviewFilter = 'negative'" class="px-2.5 py-1 rounded-md text-[11px] font-bold transition-colors whitespace-nowrap" :class="reviewFilter === 'negative' ? 'bg-red-600 text-white' : 'bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400 hover:bg-slate-200 dark:hover:bg-slate-700'">Negative</button>
