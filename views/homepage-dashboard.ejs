                                                    <div class="absolute bottom-2 right-2 flex gap-1">
                                                        <button @click="showReplyEditor = false" class="px-2 py-1 bg-slate-100 hover:bg-slate-200 text-slate-600 text-[9px] font-bold rounded transition-colors">Cancel</button>
                                                        <button @click="publishReviewReply(review); showReplyEditor = false" class="px-2 py-1 bg-blue-600 hover:bg-blue-700 text-white text-[9px] font-bold rounded transition-colors shadow-sm inline-flex items-center gap-1" :disabled="review.isPublishing">
                                                            <span x-show="!review.isPublishing">Approve & Publish</span>
                                                            <svg x-show="review.isPublishing" class="animate-spin h-2.5 w-2.5" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
