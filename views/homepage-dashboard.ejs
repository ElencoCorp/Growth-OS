<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Growth OS — AI-Powered Local Marketing Platform</title>
    <meta name="description" content="Growth OS is the AI-first local business growth platform. Manage reviews, rankings, posts, and competitors from a single enterprise dashboard.">

    <!-- Google Fonts: Inter (Primary) + JetBrains Mono (Monospace accents) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">

    <!-- Tailwind CSS (compiled locally) -->
    <link href="/public/output.css" rel="stylesheet">

    <!-- Alpine.js v3 -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
        .font-mono-accent { font-family: 'JetBrains Mono', monospace; }

        /* Glassmorphism Nav */
        .nav-glass {
            background: rgba(255, 255, 255, 0.72);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
        }

        /* Smooth card lift on hover */
        .card-lift {
            transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
        }
        .card-lift:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06), 0 2px 8px rgba(0, 0, 0, 0.04);
        }

        /* Command palette search focus ring */
        .search-input:focus {
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
        }

        /* Scrollbar styling */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }

        /* Notification pulse */
        @keyframes notif-pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.3); opacity: 0.7; }
        }
        .notif-dot { animation: notif-pulse 2s ease-in-out infinite; }

        /* Subtle entrance animations */
        @keyframes fade-up {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-up {
            animation: fade-up 0.5s ease-out forwards;
        }
        .animate-fade-up-delay-1 { animation-delay: 0.08s; opacity: 0; }
        .animate-fade-up-delay-2 { animation-delay: 0.16s; opacity: 0; }
        .animate-fade-up-delay-3 { animation-delay: 0.24s; opacity: 0; }
        .animate-fade-up-delay-4 { animation-delay: 0.32s; opacity: 0; }
    </style>
</head>

<body class="bg-[#F9FAFB] text-slate-800 antialiased min-h-screen"
      x-data="homepageDashboard()"
      x-init="init()">

    <!-- ═══════════════════════════════════════════════════════════════════════
         I.  GLOBAL NAVIGATION BAR — Sticky Glassmorphism Header
         ═══════════════════════════════════════════════════════════════════════ -->
    <header class="nav-glass sticky top-0 z-50 border-b border-slate-200/60" id="global-nav">
        <div class="max-w-[1440px] mx-auto px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">

                <!-- ── Left Block: Logo + Nav Links ── -->
                <div class="flex items-center gap-8">
                    <!-- Platform Logo -->
                    <a href="/homepage" class="flex items-center gap-2.5 group shrink-0" id="logo-link">
                        <div class="w-8 h-8 bg-gradient-to-br from-blue-600 to-indigo-600 rounded-lg flex items-center justify-center shadow-md shadow-blue-600/20 group-hover:shadow-blue-600/30 transition-shadow">
                            <svg class="w-4.5 h-4.5 text-white" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                            </svg>
                        </div>
                        <span class="text-[17px] font-extrabold tracking-tight text-slate-900">Growth<span class="text-blue-600">OS</span></span>
                    </a>

                    <!-- Horizontal Navigation Array -->
                    <nav class="hidden lg:flex items-center gap-1" id="primary-nav">
                        <template x-for="item in navItems" :key="item.key">
                            <button
                                @click="activeNav = item.key"
                                :class="activeNav === item.key
                                    ? 'text-blue-600 bg-blue-50/80 font-semibold'
                                    : 'text-slate-500 hover:text-slate-800 hover:bg-slate-100/60 font-medium'"
                                class="px-3 py-1.5 text-[13px] rounded-lg transition-all duration-200 whitespace-nowrap"
                                x-text="item.label">
                            </button>
                        </template>
                    </nav>
                </div>

                <!-- ── Center Block: Command Palette Search ── -->
                <div class="hidden md:flex flex-1 max-w-md mx-8" id="search-block">
                    <div class="relative w-full group">
                        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-slate-400 group-focus-within:text-blue-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                            </svg>
                        </div>
                        <input
                            type="text"
                            placeholder="Search businesses, reviews, posts..."
                            class="search-input w-full bg-slate-100/70 border border-slate-200/80 rounded-xl pl-10 pr-20 py-2 text-sm text-slate-700 placeholder:text-slate-400 focus:outline-none focus:border-blue-300 focus:bg-white transition-all duration-200"
                            id="command-search">
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <kbd class="hidden sm:inline-flex items-center gap-1 px-2 py-0.5 text-[10px] font-mono-accent font-medium text-slate-400 bg-white border border-slate-200 rounded-md shadow-sm">
                                <span class="text-[11px]">⌘</span>K
                            </kbd>
                        </div>
                    </div>
                </div>

                <!-- ── Right Block: Notifications + Profile Avatar ── -->
                <div class="flex items-center gap-3 shrink-0" id="user-actions">
                    <!-- Notification Bell -->
                    <button class="relative p-2 rounded-xl hover:bg-slate-100/70 transition-colors group" id="notification-bell" @click="showNotifications = !showNotifications">
                        <svg class="w-5 h-5 text-slate-500 group-hover:text-slate-700 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                        </svg>
                        <!-- Active Alert Dot -->
                        <span x-show="notificationCount > 0" class="notif-dot absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full ring-2 ring-white"></span>

                        <!-- Notification Dropdown -->
                        <div x-show="showNotifications" @click.away="showNotifications = false"
                             x-transition:enter="transition ease-out duration-200"
                             x-transition:enter-start="opacity-0 translate-y-1 scale-95"
                             x-transition:enter-end="opacity-1 translate-y-0 scale-100"
                             x-transition:leave="transition ease-in duration-150"
                             x-transition:leave-start="opacity-1 translate-y-0 scale-100"
                             x-transition:leave-end="opacity-0 translate-y-1 scale-95"
                             class="absolute right-0 top-full mt-2 w-80 bg-white border border-slate-200 rounded-2xl shadow-xl shadow-slate-200/50 overflow-hidden" style="display: none;">
                            <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between">
                                <h4 class="text-sm font-bold text-slate-900">Notifications</h4>
                                <span class="text-[11px] font-semibold text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full" x-text="notificationCount + ' new'"></span>
                            </div>
                            <div class="max-h-64 overflow-y-auto divide-y divide-slate-50">
                                <template x-for="notif in notifications" :key="notif.id">
                                    <div class="px-4 py-3 hover:bg-slate-50/80 transition-colors cursor-pointer">
                                        <p class="text-sm text-slate-700 font-medium leading-snug" x-text="notif.message"></p>
                                        <p class="text-[11px] text-slate-400 mt-1" x-text="notif.time"></p>
                                    </div>
                                </template>
                            </div>
                        </div>
                    </button>

                    <!-- Divider -->
                    <div class="w-px h-6 bg-slate-200 hidden sm:block"></div>

                    <!-- Profile Avatar -->
                    <div class="relative" x-data="{ showProfile: false }" id="profile-avatar-block">
                        <button @click="showProfile = !showProfile" class="flex items-center gap-2.5 p-1.5 rounded-xl hover:bg-slate-100/70 transition-all duration-200 group">
                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center text-white text-xs font-bold shadow-md shadow-violet-500/20 ring-2 ring-white">
                                S
                            </div>
                            <div class="hidden sm:block text-left">
                                <p class="text-[13px] font-semibold text-slate-700 leading-tight">Shreyans</p>
                                <p class="text-[11px] text-slate-400 leading-tight">Admin</p>
                            </div>
                            <svg class="w-3.5 h-3.5 text-slate-400 hidden sm:block transition-transform duration-200" :class="showProfile ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </button>

                        <!-- Profile Dropdown -->
                        <div x-show="showProfile" @click.away="showProfile = false"
                             x-transition:enter="transition ease-out duration-200"
                             x-transition:enter-start="opacity-0 translate-y-1 scale-95"
                             x-transition:enter-end="opacity-1 translate-y-0 scale-100"
                             class="absolute right-0 top-full mt-2 w-56 bg-white border border-slate-200 rounded-2xl shadow-xl shadow-slate-200/50 overflow-hidden" style="display: none;">
                            <div class="px-4 py-3 border-b border-slate-100 bg-slate-50/50">
                                <p class="text-sm font-bold text-slate-900">Shreyans Patel</p>
                                <p class="text-xs text-slate-500 mt-0.5">shreyans@growthcorp.io</p>
                            </div>
                            <div class="py-1">
                                <button class="w-full text-left px-4 py-2.5 text-sm text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors font-medium flex items-center gap-2.5">
                                    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                    Account Settings
                                </button>
                                <button class="w-full text-left px-4 py-2.5 text-sm text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors font-medium flex items-center gap-2.5">
                                    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                                    Switch Organization
                                </button>
                            </div>
                            <div class="border-t border-slate-100 py-1">
                                <button class="w-full text-left px-4 py-2.5 text-sm text-red-500 hover:bg-red-50 hover:text-red-600 transition-colors font-medium flex items-center gap-2.5">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                                    Sign Out
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </header>

    <!-- ═══════════════════════════════════════════════════════════════════════
         II.  MAIN CONTENT AREA
         ═══════════════════════════════════════════════════════════════════════ -->
    <main class="max-w-[1440px] mx-auto px-6 lg:px-8 py-8" id="main-content">

        <!-- ─── WELCOME HERO: Personalized Briefing Banner ─── -->
        <section class="animate-fade-up" id="welcome-hero">
            <div class="bg-white rounded-[20px] border border-slate-200/80 shadow-sm p-8 mb-6 card-lift relative overflow-hidden">

                <!-- Subtle background gradient accent -->
                <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-gradient-to-bl from-blue-50/80 via-indigo-50/40 to-transparent rounded-full -mr-32 -mt-32 pointer-events-none"></div>
                <div class="absolute bottom-0 left-0 w-[200px] h-[200px] bg-gradient-to-tr from-emerald-50/60 to-transparent rounded-full -ml-16 -mb-16 pointer-events-none"></div>

                <!-- 2-Column Grid -->
                <div class="relative z-10 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8">

                    <!-- Left Column: Greeting + CTAs -->
                    <div class="flex-1 min-w-0">
                        <!-- Greeting -->
                        <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-slate-900 leading-tight" id="hero-greeting">
                            Good <span x-text="timeOfDay"></span>, Shreyans 👋
                        </h1>
                        <p class="text-[15px] text-slate-500 mt-2 leading-relaxed max-w-lg">
                            Here's your local growth snapshot for <span class="font-semibold text-slate-600" x-text="todayFormatted"></span>. Your AI campaigns are performing well.
                        </p>

                        <!-- CTA Buttons -->
                        <div class="flex flex-wrap items-center gap-3 mt-6">
                            <!-- Primary: Create AI Campaign -->
                            <button class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#2563EB] hover:bg-[#1d4ed8] text-white text-sm font-semibold rounded-xl shadow-md shadow-blue-600/20 hover:shadow-blue-600/30 transition-all duration-300 active:scale-[0.98]" id="cta-create-campaign">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                                </svg>
                                Create AI Campaign
                            </button>
                            <!-- Secondary: Connect Business -->
                            <button class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-[#2563EB] text-sm font-semibold rounded-xl border-2 border-blue-200 hover:border-blue-300 hover:bg-blue-50/50 transition-all duration-300 active:scale-[0.98]" id="cta-connect-business">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                                </svg>
                                Connect Business
                            </button>
                        </div>
                    </div>

                    <!-- Right Column: Micro-Badge Achievement Deck -->
                    <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-2 xl:grid-cols-4 gap-3 lg:max-w-md xl:max-w-lg shrink-0" id="achievement-deck">

                        <!-- Badge 1: +28 Reviews -->
                        <div class="animate-fade-up animate-fade-up-delay-1 bg-emerald-50/80 border border-emerald-100 rounded-2xl p-4 text-center card-lift">
                            <div class="w-10 h-10 mx-auto mb-2.5 bg-emerald-100 rounded-xl flex items-center justify-center">
                                <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                                </svg>
                            </div>
                            <p class="text-lg font-extrabold text-emerald-700 tracking-tight font-mono-accent">+28</p>
                            <p class="text-[11px] font-semibold text-emerald-600/80 uppercase tracking-wider mt-0.5">Reviews</p>
                        </div>

                        <!-- Badge 2: +17,000 Views -->
                        <div class="animate-fade-up animate-fade-up-delay-2 bg-slate-50/80 border border-slate-200/80 rounded-2xl p-4 text-center card-lift">
                            <div class="w-10 h-10 mx-auto mb-2.5 bg-slate-100 rounded-xl flex items-center justify-center">
                                <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                            </div>
                            <p class="text-lg font-extrabold text-slate-700 tracking-tight font-mono-accent">+17k</p>
                            <p class="text-[11px] font-semibold text-slate-500/80 uppercase tracking-wider mt-0.5">Views</p>
                        </div>

                        <!-- Badge 3: +310 Calls -->
                        <div class="animate-fade-up animate-fade-up-delay-3 bg-sky-50/80 border border-sky-100 rounded-2xl p-4 text-center card-lift">
                            <div class="w-10 h-10 mx-auto mb-2.5 bg-sky-100 rounded-xl flex items-center justify-center">
                                <svg class="w-5 h-5 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                </svg>
                            </div>
                            <p class="text-lg font-extrabold text-sky-700 tracking-tight font-mono-accent">+310</p>
                            <p class="text-[11px] font-semibold text-sky-600/80 uppercase tracking-wider mt-0.5">Calls</p>
                        </div>

                        <!-- Badge 4: +19 Photos -->
                        <div class="animate-fade-up animate-fade-up-delay-4 bg-indigo-50/80 border border-indigo-100 rounded-2xl p-4 text-center card-lift">
                            <div class="w-10 h-10 mx-auto mb-2.5 bg-indigo-100 rounded-xl flex items-center justify-center">
                                <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                            </div>
                            <p class="text-lg font-extrabold text-indigo-700 tracking-tight font-mono-accent">+19</p>
                            <p class="text-[11px] font-semibold text-indigo-600/80 uppercase tracking-wider mt-0.5">Photos</p>
                        </div>

                    </div>
                </div>
            </div>
        </section>

        <!-- ─── Placeholder: Future Sections (Part 2+) will mount below ─── -->
        <section class="animate-fade-up animate-fade-up-delay-2" id="dashboard-modules-slot">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                <!-- Module Slot 1 -->
                <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm p-6 card-lift">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 bg-blue-50 rounded-xl flex items-center justify-center">
                            <svg class="w-4.5 h-4.5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                        </div>
                        <h3 class="text-sm font-bold text-slate-900">Performance Analytics</h3>
                    </div>
                    <p class="text-sm text-slate-500 leading-relaxed">Real-time conversion metrics across all connected business profiles.</p>
                    <div class="mt-4 pt-4 border-t border-slate-100 flex items-center justify-between">
                        <span class="text-2xl font-extrabold text-slate-900 tracking-tight font-mono-accent">12.4k</span>
                        <span class="text-xs font-semibold text-emerald-600 bg-emerald-50 px-2.5 py-1 rounded-lg">↑ 18.2%</span>
                    </div>
                </div>

                <!-- Module Slot 2 -->
                <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm p-6 card-lift">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 bg-amber-50 rounded-xl flex items-center justify-center">
