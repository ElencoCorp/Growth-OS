            <div class="bg-white dark:bg-[#111827] rounded-2xl border border-slate-200/80 dark:border-[#1F2937] shadow-sm dark:shadow-none p-6 relative overflow-hidden">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
                    <div>
                        <h2 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-2">
                            <div class="w-8 h-8 rounded-lg bg-indigo-50 dark:bg-indigo-900/30 flex items-center justify-center">
                                <svg class="w-4 h-4 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                            </div>
                            Competitor Intelligence Radar
                        </h2>
                        <p class="text-sm text-slate-500 mt-1 ml-10">Real-time local market rival tracking.</p>
                    </div>
                </div>
                
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <template x-if="!stats.competitors || stats.competitors.length === 0">
                        <div class="col-span-full py-12 text-center border-2 border-dashed border-slate-200 dark:border-slate-800 rounded-2xl">
                            <p class="text-slate-500 text-sm">No competitors tracked for this location.</p>
                        </div>
                    </template>
                    <template x-for="competitor in (stats.competitors || [])" :key="competitor.id">
                        <div class="bg-white dark:bg-[#111827] border-2 border-slate-100 dark:border-slate-800 rounded-2xl p-6 transition-all hover:border-indigo-500/30 hover:shadow-lg relative overflow-hidden group">
                            <!-- Background Accent -->
                            <div class="absolute top-0 right-0 w-32 h-32 bg-indigo-50 dark:bg-indigo-900/10 rounded-full blur-[40px] -mr-10 -mt-10 pointer-events-none"></div>
                            
                            <!-- Header: vs match and score -->
                            <div class="flex items-start justify-between mb-6 relative z-10">
                                <div>
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="text-lg font-black text-slate-900 dark:text-white truncate max-w-[180px]" x-text="competitor.name"></span>
                                        <span class="text-xs font-bold text-slate-400 italic">vs</span>
                                        <span class="text-sm font-bold text-indigo-600 dark:text-indigo-400">You</span>
                                    </div>
                                    <div class="text-xs font-medium text-slate-500 flex items-center gap-2">
                                        <span x-text="'Rank #' + competitor.currentRank"></span>
                                        <span class="w-1 h-1 rounded-full bg-slate-300 dark:bg-slate-700"></span>
                                        <span x-text="competitor.reviewCount + ' Reviews'"></span>
                                        <span class="w-1 h-1 rounded-full bg-slate-300 dark:bg-slate-700"></span>
                                        <span class="text-amber-500 font-bold" x-text="competitor.averageRating + ' ⭐'"></span>
                                    </div>
                                </div>
                                <div class="shrink-0 text-right">
                                    <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg"
                                         :class="competitor.currentRank > 3 ? 'bg-emerald-50 text-emerald-700 border border-emerald-100' : 'bg-amber-50 text-amber-700 border border-amber-100'">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                                        <span class="text-[10px] font-black uppercase tracking-wider" x-text="competitor.currentRank > 3 ? 'Opportunity Score: 78% (Easy Win)' : 'Opportunity Score: 42% (Tough)'"></span>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Body: AI Action -->
                            <div class="bg-slate-50 dark:bg-[#1F2937]/50 rounded-xl p-4 border border-slate-100 dark:border-slate-800 relative z-10">
                                <button @click="generateCounterStrategy(competitor)" 
                                        :disabled="competitor.isGenerating === true"
                                        class="w-full px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold rounded-xl shadow-sm shadow-indigo-500/20 disabled:opacity-50 transition-all flex items-center justify-center gap-2">
                                    <span x-show="!competitor.isGenerating">Generate AI Counter-Strategy Blueprint</span>
                                    <span x-show="competitor.isGenerating" class="flex items-center gap-2">
                                        <svg class="animate-spin h-3.5 w-3.5 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                                        Analyzing Local Market Gaps...
                                    </span>
                                </button>
                                
                                <div x-show="competitor.aiStrategyText" x-transition class="mt-4 pt-4 border-t border-slate-200 dark:border-slate-700">
                                    <div class="flex items-center gap-2 mb-2 text-indigo-600 dark:text-indigo-400">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                        <span class="text-xs font-bold uppercase tracking-wider">AI Remediation Blueprint</span>
                                    </div>
                                    <p class="text-xs text-slate-700 dark:text-slate-300 whitespace-pre-wrap leading-relaxed" x-text="competitor.aiStrategyText"></p>
                                    <button class="mt-3 text-xs font-bold text-indigo-600 hover:text-indigo-700 underline underline-offset-2">1-Click Execute Strategy</button>
                                </div>
                            </div>
                        </div>
                    </template>
                </div>
            </div>
        </section>


        <!-- â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
             FIX EVERYTHING WITH AI â€” MODAL
             â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
        <div x-show="showFixModal" 
             x-cloak
             class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/80 backdrop-blur-sm"
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition ease-in duration-200"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0">
            
            <div class="bg-white dark:bg-[#111827] rounded-3xl border border-slate-200 dark:border-[#1F2937] shadow-2xl w-full max-w-lg overflow-hidden transform transition-all"
                 @click.away="!isExecuting ? showFixModal = false : null">
                 
                <!-- Header -->
                <div class="bg-gradient-to-r from-purple-600 to-blue-600 p-6 flex justify-between items-start">
                    <div>
                        <h2 class="text-xl font-bold text-white tracking-tight">AI Auto-Pilot</h2>
                        <p class="text-purple-100 text-sm mt-1">Review the tasks that will be executed.</p>
                    </div>
                    <button @click="showFixModal = false" :disabled="isExecuting" class="text-purple-200 hover:text-white transition-colors disabled:opacity-50">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>

                <!-- Body Checklist -->
                <div class="p-6 space-y-4">
                    <ul class="space-y-3">
                        <li class="flex items-center gap-3" x-show="stats.pendingReviews > 0">
                            <div class="w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center shrink-0">
                                <svg class="w-4 h-4 text-emerald-600 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                            </div>
                            <span class="text-sm font-medium text-slate-700 dark:text-slate-300">Draft and publish sentiment-matched replies to <strong x-text="stats.pendingReviews"></strong> pending reviews.</span>
                        </li>
                        <li class="flex items-center gap-3" x-show="stats.pendingTasks > 0">
                            <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center shrink-0">
                                <svg class="w-4 h-4 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                            </div>
                            <span class="text-sm font-medium text-slate-700 dark:text-slate-300">Auto-approve and queue <strong x-text="stats.pendingTasks"></strong> drafted promotional posts.</span>
                        </li>
                    </ul>

                    <!-- Progress Bar -->
                    <div x-show="isExecuting" class="mt-8 space-y-2">
                        <div class="flex justify-between items-center text-xs font-semibold text-slate-600 dark:text-slate-400">
                            <span>Executing pipelines...</span>
                            <span x-text="fixProgress + '%'"></span>
                        </div>
                        <div class="w-full bg-slate-200 dark:bg-slate-700 rounded-full h-2 overflow-hidden">
                            <div class="bg-gradient-to-r from-blue-500 to-purple-600 h-2 rounded-full transition-all duration-300 ease-out"
                                 :style="`width: ${fixProgress}%`"></div>
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="p-6 bg-slate-50 dark:bg-[#1F2937]/50 border-t border-slate-100 dark:border-slate-800 flex justify-end gap-3">
                    <button @click="showFixModal = false" :disabled="isExecuting" class="px-5 py-2 text-sm font-semibold text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition-colors disabled:opacity-50">Cancel</button>
                    <button @click="startAutoPilot()" :disabled="isExecuting" class="px-6 py-2 bg-purple-600 hover:bg-purple-700 active:scale-[0.98] text-white font-bold text-sm rounded-xl transition-all shadow-md shadow-purple-600/20 disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2">
                        <span x-show="!isExecuting">Confirm Execution</span>
                        <span x-show="isExecuting" class="flex items-center gap-2">
                            <svg class="animate-spin h-4 w-4 text-white" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            Running
                        </span>
                    </button>
                </div>
            </div>
        </div>

    </main>
