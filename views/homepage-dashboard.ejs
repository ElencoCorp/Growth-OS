    <script>
        function homepageDashboard() {
            return {
                // Navigation State
                activeNav: 'dashboard',
                navItems: [
                    { key: 'dashboard',    label: 'Dashboard' },
                    { key: 'businesses',   label: 'Businesses' },
                    { key: 'ai-studio',    label: 'AI Studio' },
                    { key: 'posts',        label: 'Posts' },
                    { key: 'reviews',      label: 'Reviews' },
                    { key: 'rankings',     label: 'Rankings' },
                    { key: 'competitors',  label: 'Competitors' },
                    { key: 'analytics',    label: 'Analytics' },
                    { key: 'automations',  label: 'Automations' },
                    { key: 'settings',     label: 'Settings' }
                ],

                // Notification State
                showNotifications: false,
                notificationCount: 3,
                notifications: [
                    { id: 1, message: 'New 5-star review on "Growth Dental Clinic — Ravet"', time: '2 min ago' },
                    { id: 2, message: 'AI post draft ready for approval: "Summer Wellness Tips"', time: '18 min ago' },
                    { id: 3, message: 'Competitor ranking change detected in Pimpri-Chinchwad', time: '1 hour ago' }
                ],

                // Time helpers
                timeOfDay: '',
                todayFormatted: '',

                init() {
                    const hour = new Date().getHours();
                    if (hour < 12) this.timeOfDay = 'Morning';
                    else if (hour < 17) this.timeOfDay = 'Afternoon';
                    else this.timeOfDay = 'Evening';

                    this.todayFormatted = new Date().toLocaleDateString('en-IN', {
                        weekday: 'long',
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                    });

                    // Keyboard shortcut for command palette
                    document.addEventListener('keydown', (e) => {
                        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
                            e.preventDefault();
                            document.getElementById('command-search')?.focus();
                        }
                    });
                }
            };
        }
    </script>

