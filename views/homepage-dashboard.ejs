                                <%= stats.gmb && stats.gmb.directions.growth >= 0 ? 'â†‘' : 'â†“' %> <%= stats.gmb ? Math.abs(stats.gmb.directions.growth) : 0 %>%
                            </span>
                        </div>
                        <p class="mt-1 text-2xl font-black font-mono tracking-tight text-purple-900 dark:text-purple-300 group-hover:scale-[1.02] transition-transform" x-text="(stats.gmb.directions.current || 0).toLocaleString()">
                            <%= stats.gmb ? stats.gmb.directions.current.toLocaleString() : '0' %>
                        </p>
                    </div>

                    <!-- Badge 5: Website Clicks -->
                    <div class="p-4 bg-amber-50/60 dark:bg-amber-900/10 border border-amber-100 dark:border-amber-800/50 rounded-2xl transition-all duration-300 hover:shadow-md group flex flex-col justify-between md:col-span-3 lg:col-span-1">
