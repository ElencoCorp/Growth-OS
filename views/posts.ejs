<div class="max-w-[1440px] mx-auto px-6 lg:px-8 py-8" id="main-content">
    <div class="mb-8 flex justify-between items-end">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Scheduled Posts</h1>
            <p class="text-slate-500 dark:text-slate-400 mt-1">Manage your upcoming and published Google Business Profile content.</p>
        </div>
        <button class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition-all shadow-sm">Create Post</button>
    </div>

    <div class="bg-white dark:bg-[#111827] rounded-2xl border border-slate-200/80 dark:border-[#1F2937] overflow-hidden shadow-sm">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 dark:bg-[#1F2937]/50 border-b border-slate-200 dark:border-[#1F2937]">
                    <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Content</th>
                    <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
                    <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Scheduled For</th>
                    <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-[#1F2937]">
                <% if (posts && posts.length > 0) { %>
                    <% posts.forEach(function(post) { %>
                        <tr class="hover:bg-slate-50/50 dark:hover:bg-[#1F2937]/30 transition-colors">
                            <td class="px-6 py-4">
                                <p class="text-sm font-medium text-slate-900 dark:text-white truncate max-w-md"><%= post.content.substring(0, 80) %>...</p>
                            </td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-1 rounded-md text-[10px] font-bold tracking-wider uppercase <%= post.status === 'PUBLISHED' ? 'bg-emerald-50 text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400' : 'bg-blue-50 text-blue-600 dark:bg-blue-500/10 dark:text-blue-400' %>">
                                    <%= post.status %>
                                </span>
                            </td>
                            <td class="px-6 py-4 text-sm text-slate-500 dark:text-slate-400">
                                <%= new Date(post.scheduledFor).toLocaleDateString() %>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <button class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 text-sm font-medium">Edit</button>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="4" class="px-6 py-12 text-center text-slate-500 dark:text-slate-400 text-sm">
                            No posts found for this location. Generate some in the AI Studio.
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
