             style="display: none;">
            <a href="/" class="block px-3 py-2 rounded-lg text-sm font-medium text-blue-600 bg-blue-50">Dashboard</a>
            <a href="/businesses" class="block px-3 py-2 rounded-lg text-sm font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition-all">Businesses</a>
