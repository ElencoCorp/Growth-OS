<!DOCTYPE html>
<html lang="en" class="h-full" x-data="{ darkMode: $persist(false) }" :class="{ 'dark': darkMode }">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Growth-OS Enterprise Dashboard</title>
    <meta name="description" content="Growth-OS is the AI-first local business growth platform for agencies managing clinics, hotels, and multi-location brands across India.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/@alpinejs/persist@3.x.x/dist/cdn.min.js" defer></script>
    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Plus Jakarta Sans', 'system-ui', '-apple-system', 'BlinkMacSystemFont', 'Segoe UI', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        [x-cloak] { display: none !important; }
        @keyframes fade-up {
            from { opacity: 0; transform: translateY(16px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-up { animation: fade-up 0.5s ease-out forwards; }
        .animate-delay-1 { animation-delay: 0.06s; opacity: 0; }
        .animate-delay-2 { animation-delay: 0.12s; opacity: 0; }
        .animate-delay-3 { animation-delay: 0.18s; opacity: 0; }
        .animate-delay-4 { animation-delay: 0.24s; opacity: 0; }
    </style>
</head>
<body class="bg-slate-50 dark:bg-[#09090B] min-h-screen text-slate-900 dark:text-white transition-colors duration-300" x-data="dashboardState()">

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         SECTION I â€” FIXED GLASSMORPHISM GLOBAL HEADER
         â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    <header x-data="{ accountOpen: false, mobileMenuOpen: false }"
            class="sticky top-0 z-50 w-full backdrop-blur-md bg-white/70 dark:bg-[#09090B]/80 border-b border-slate-200/80 dark:border-slate-800"
            id="global-header">
        <div class="max-w-[1440px] mx-auto px-4 lg:px-6 py-2.5 flex items-center justify-between gap-4">

            <!-- â”€â”€ LEFT BLOCK: BRAND LOGO & CORE ROUTING LINKS â”€â”€ -->
            <div class="flex items-center space-x-4 lg:space-x-8 shrink-0">
                <div class="relative flex items-center" x-data="{ orgOpen: false }">
                    <button @click="orgOpen = !orgOpen" class="flex items-center space-x-2 cursor-pointer group focus:outline-none" id="brand-logo">
                        <div class="h-7 w-7 bg-blue-600 rounded-lg flex items-center justify-center shadow-sm shadow-blue-500/20 group-hover:shadow-blue-500/30 transition-shadow duration-300">
                            <span class="text-white text-xs font-black font-mono tracking-tighter">G</span>
                        </div>
                        <span class="text-[15px] font-extrabold tracking-tight text-slate-900 dark:text-white"><%= organization ? organization.name : 'Growth-OS' %></span>
                        <svg class="h-4 w-4 text-slate-400 group-hover:text-slate-600 dark:group-hover:text-slate-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div x-show="orgOpen" @click.away="orgOpen = false" x-cloak
                         class="absolute left-0 top-full mt-2 w-64 bg-white dark:bg-[#111827] border border-slate-200 dark:border-slate-700 rounded-xl shadow-lg z-50 py-1">
                        <% if (typeof organizations !== 'undefined' && organizations.length > 0) { %>
                            <% organizations.forEach(function(org) { %>
                                <a href="javascript:void(0)" @click="switchOrganization(<%= org.id %>)"
                                   class="block px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800">
                                    <%= org.name %>
                                </a>
                            <% }); %>
                        <% } else { %>
                            <span class="block px-4 py-2 text-sm text-slate-500">No organizations found</span>
                        <% } %>
                    </div>
                </div>
                <nav class="hidden lg:flex items-center space-x-1 shrink-0" id="primary-nav">
                    <a href="/" class="px-2.5 py-1.5 rounded-lg text-sm font-medium text-blue-600 bg-blue-50 transition-all duration-200">Dashboard</a>
                    <a href="/businesses" class="px-2.5 py-1.5 rounded-lg text-sm font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition-all duration-200">Businesses</a>
                    <a href="/studio" class="px-2.5 py-1.5 rounded-lg text-sm font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition-all duration-200">AI Studio</a>
                    <a href="/analytics" class="px-2.5 py-1.5 rounded-lg text-sm font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition-all duration-200">Analytics</a>
                </nav>
                <!-- Mobile hamburger -->
                <button @click="mobileMenuOpen = !mobileMenuOpen" class="lg:hidden p-2 rounded-lg hover:bg-slate-100 transition-colors">
                    <svg class="h-5 w-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </button>
            </div>

            <!-- ── CENTER BLOCK: INLINE COMMAND SEARCH BAR ── -->
            <div class="relative hidden md:block flex-1 max-w-md min-w-[200px]" id="search-command-bar" @keydown.window.cmd.k.prevent="focusSearch()" @keydown.window.ctrl.k.prevent="focusSearch()">
                <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
                    <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                </div>
                <input type="text"
                       x-model="searchQuery"
                       @input.debounce.300ms="performSearch()"
                       @focus="searchFocused = true"
                       @blur="setTimeout(() => searchFocused = false, 200)"
                       placeholder="Search actions or metrics..."
                       class="w-full bg-slate-100/80 border border-slate-200 dark:border-[#1F2937] rounded-xl pl-9 pr-12 py-2 text-sm text-slate-800 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-400 focus:bg-white dark:bg-[#111827] transition-all duration-200"
                       id="command-search-input">
                <div class="absolute inset-y-0 right-3 flex items-center pointer-events-none">
                    <kbd class="hidden sm:inline-block px-1.5 py-0.5 text-[10px] font-mono font-medium text-slate-400 bg-white dark:bg-[#111827] border border-slate-200 dark:border-[#1F2937] rounded-md shadow-sm dark:shadow-none">⌘K</kbd>
                </div>
                
                <!-- Floating Dropdown Overlay -->
                <div x-show="searchFocused && searchQuery.length >= 2" x-transition x-cloak
                     class="absolute top-full left-0 right-0 mt-2 bg-white dark:bg-[#111827] border border-slate-200 dark:border-slate-700 rounded-xl shadow-2xl z-50 overflow-hidden max-h-96 overflow-y-auto">
                    
                    <div x-show="isSearching" class="p-4 text-center text-sm text-slate-500 flex items-center justify-center gap-2">
                        <svg class="animate-spin h-4 w-4 text-blue-500" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        Searching...
                    </div>
                    
                    <div x-show="!isSearching && searchResults.length === 0" class="p-4 text-center text-sm text-slate-500">
                        No results found for "<span x-text="searchQuery"></span>".
                    </div>

                    <div x-show="!isSearching && searchResults.length > 0">
                        <template x-for="result in searchResults" :key="result.id">
                            <a :href="result.url" class="block px-4 py-3 hover:bg-slate-50 dark:hover:bg-[#1F2937] border-b border-slate-100 dark:border-slate-800 last:border-0 transition-colors cursor-pointer">
                                <div class="flex items-center justify-between mb-1">
                                    <span class="text-xs font-bold px-2 py-0.5 rounded uppercase tracking-wider" 
                                          :class="{
                                              'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400': result.type === 'Review',
                                              'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400': result.type === 'Post',
                                              'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400': result.type === 'Location',
                                              'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400': result.type === 'Competitor'
                                          }" x-text="result.type"></span>
                                </div>
                                <div class="text-sm font-semibold text-slate-900 dark:text-white truncate" x-text="result.title"></div>
                                <div class="text-xs text-slate-500 truncate mt-0.5" x-text="result.description"></div>
                            </a>
                        </template>
                    </div>
                </div>
            </div>

            <!-- ── RIGHT BLOCK: INTERACTIVE NOTIFICATIONS & CONTEXT AVATARS ── -->
            <div class="flex items-center gap-2 lg:gap-3 shrink-0" id="right-actions">
                <!-- 4. Quick Create Button (+) -->
                <button @click="$dispatch('open-campaign-wizard')" class="h-8 w-8 bg-blue-600 hover:bg-blue-700 text-white rounded-lg flex items-center justify-center transition-colors shadow-sm focus:outline-none" title="Create AI Campaign">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                </button>

                <div class="w-px h-5 bg-slate-200 dark:bg-slate-700 hidden lg:block"></div>

                <!-- 5. Google Connected Check Token -->
                <div class="hidden xl:flex items-center space-x-1.5 px-2.5 py-1 bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-100 dark:border-emerald-800/50 rounded-lg" title="Google Sync Status">
                    <svg class="h-3.5 w-3.5 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    <span class="text-[11px] font-semibold text-emerald-700 dark:text-emerald-400">Connected <span class="text-emerald-600/70 dark:text-emerald-500/70 font-normal hidden 2xl:inline">/ Sync: 2m ago</span></span>
                </div>

                <!-- 6. Business Switcher Dropdown (Locations) -->
                <div class="relative hidden sm:block" x-data="{ locationOpen: false }">
                    <button @click="locationOpen = !locationOpen" class="flex items-center space-x-1.5 px-2.5 py-1.5 bg-slate-100 dark:bg-slate-800 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors focus:outline-none max-w-[150px]">
                        <span class="text-sm font-medium text-slate-700 dark:text-slate-300 truncate" x-text="activeLocation ? activeLocation.name : 'Select Location'"><%= activeLocation ? activeLocation.name : 'Select Location' %></span>
                        <svg class="h-3.5 w-3.5 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div x-show="locationOpen" @click.away="locationOpen = false" x-cloak
                         class="absolute right-0 mt-2 w-56 bg-white dark:bg-[#111827] border border-slate-200 dark:border-slate-700 rounded-xl shadow-lg z-50 py-1">
                        <% if (typeof locations !== 'undefined' && locations.length > 0) { %>
                            <% locations.forEach(function(loc) { %>
                                <a href="javascript:void(0)" @click="switchLocation(<%= loc.id %>)"
                                   class="block px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800">
                                    <%= loc.name %>
                                </a>
                            <% }); %>
                        <% } else { %>
                            <span class="block px-4 py-2 text-sm text-slate-500">No locations found</span>
                        <% } %>
                    </div>
                </div>
                <!-- Notification Bell -->
                <div class="relative" x-data="{ notificationsOpen: false }">
                    <button @click="notificationsOpen = !notificationsOpen" class="relative p-2 text-slate-500 hover:text-slate-700 hover:bg-slate-100 dark:hover:bg-slate-800 dark:text-slate-400 dark:hover:text-slate-200 rounded-xl transition-all duration-200" id="notification-bell-btn">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                        <span x-show="stats.unreadCount > 0" x-cloak class="absolute top-1 right-1 flex items-center justify-center h-4 w-4 bg-red-500 text-white text-[9px] font-bold rounded-full" x-text="stats.unreadCount"></span>
                    </button>
                    <div x-show="notificationsOpen" @click.away="notificationsOpen = false" x-cloak
                         class="absolute right-0 mt-2 w-80 bg-white dark:bg-[#111827] border border-slate-200 dark:border-slate-700 rounded-xl shadow-lg z-50 overflow-hidden flex flex-col">
                        <div class="px-4 py-3 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between">
                            <span class="text-sm font-bold text-slate-900 dark:text-white">Notifications</span>
                            <span class="text-xs text-slate-500" x-text="stats.unreadCount + ' unread'"></span>
                        </div>
                        <div class="max-h-80 overflow-y-auto">
                            <template x-if="!stats.notifications || stats.notifications.length === 0">
                                <div class="px-4 py-6 text-center text-sm text-slate-500">No recent notifications</div>
                            </template>
                            <template x-for="notif in (stats.notifications || [])" :key="notif.id">
                                <div @click="markNotificationRead(notif)" class="px-4 py-3 border-b border-slate-100 dark:border-slate-800 last:border-0 hover:bg-slate-50 dark:hover:bg-[#1F2937] transition-colors cursor-pointer" :class="notif.isRead ? 'opacity-60' : 'bg-blue-50/30 dark:bg-blue-900/10'">
                                    <div class="flex items-start justify-between">
                                        <p class="text-sm font-semibold text-slate-900 dark:text-white mb-1" x-text="notif.title"></p>
                                        <span x-show="!notif.isRead" class="mt-1 h-2 w-2 bg-blue-500 rounded-full flex-shrink-0"></span>
                                    </div>
                                    <p class="text-xs text-slate-600 dark:text-slate-400 line-clamp-2" x-text="notif.message"></p>
                                </div>
                            </template>
                        </div>
                    </div>
                </div>
                
                <!-- Dark Mode Toggle -->
                <button @click="darkMode = !darkMode" class="relative p-2 text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all duration-200" title="Toggle Dark Mode">
                    <svg x-show="!darkMode" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
                    <svg x-show="darkMode" x-cloak class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                </button>

                <div class="w-px h-6 bg-slate-200 hidden sm:block"></div>
                <div class="relative" id="account-avatar-block">
                    <button @click="accountOpen = !accountOpen" class="flex items-center space-x-2.5 p-1 rounded-xl hover:bg-slate-100/80 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500/20">
                        <div class="h-8 w-8 rounded-xl bg-gradient-to-br from-blue-600 to-indigo-600 text-white flex items-center justify-center font-bold text-sm tracking-tight border border-blue-700/50 shadow-sm shadow-blue-500/20">
                            S
                        </div>
                        <div class="hidden sm:block text-left">
                            <p class="text-[13px] font-semibold text-slate-700 leading-none">Shreyans</p>
                            <p class="text-[11px] text-slate-400 leading-none mt-0.5">Administrator</p>
                        </div>
                        <svg class="h-3.5 w-3.5 text-slate-400 hidden sm:block transition-transform duration-200" :class="accountOpen ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div x-show="accountOpen"
                         @click.away="accountOpen = false"
                         x-transition:enter="transition ease-out duration-200"
                         x-transition:enter-start="opacity-0 translate-y-1 scale-95"
                         x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                         x-transition:leave="transition ease-in duration-150"
                         x-transition:leave-start="opacity-100 translate-y-0 scale-100"
                         x-transition:leave-end="opacity-0 translate-y-1 scale-95"
                         class="absolute right-0 mt-2 w-56 bg-white dark:bg-[#111827] border border-slate-200 dark:border-[#1F2937] rounded-2xl shadow-xl shadow-slate-200/50 overflow-hidden z-50"
                         style="display: none;">
                        <div class="px-4 py-3 border-b border-slate-100 bg-slate-50/50">
                            <p class="text-sm font-bold text-slate-900">Shreyans Patel</p>
                            <p class="text-xs text-slate-500 mt-0.5">shreyans@growthcorp.io</p>
                        </div>
                        <div class="py-1">
                            <a href="/profile" class="flex items-center space-x-2.5 px-4 py-2.5 text-sm text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors font-medium">
                                <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                <span>My Profile</span>
                            </a>
                            <a href="/settings" class="flex items-center space-x-2.5 px-4 py-2.5 text-sm text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors font-medium">
                                <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                <span>Account Settings</span>
                            </a>
                            <a href="/organizations" class="flex items-center space-x-2.5 px-4 py-2.5 text-sm text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors font-medium">
                                <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                                <span>Switch Organization</span>
                            </a>
                        </div>
                        <div class="border-t border-slate-100 py-1">
                            <a href="/logout" class="flex items-center space-x-2.5 px-4 py-2.5 text-sm text-red-500 hover:bg-red-50 hover:text-red-600 transition-colors font-medium">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                                <span>Sign Out</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ── MOBILE MENU DROPDOWN ── -->
        <div x-show="mobileMenuOpen"
