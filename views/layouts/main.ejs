             x-transition:enter-end="opacity-100 translate-y-0"
             class="lg:hidden border-t border-slate-200/80 bg-white/95 backdrop-blur-md px-6 py-3 space-y-1"
             style="display: none;">
            <a href="/" class="block px-3 py-2 rounded-lg text-sm font-medium text-blue-600 bg-blue-50">Dashboard</a>
