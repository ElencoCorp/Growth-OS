<!DOCTYPE html>
<html lang="en" class="h-full" x-data="{ darkMode: $persist(false) }" :class="{ 'dark': darkMode }">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Growth-OS Enterprise Dashboard</title>
    <meta name="description" content="Growth-OS is the AI-first local business growth platform for agencies managing clinics, hotels, and multi-location brands across India.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/@alpinejs/persist@3.x.x/dist/cdn.min.js" defer></script>
    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Plus Jakarta Sans', 'system-ui', '-apple-system', 'BlinkMacSystemFont', 'Segoe UI', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        [x-cloak] { display: none !important; }
        @keyframes fade-up {
            from { opacity: 0; transform: translateY(16px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-up { animation: fade-up 0.5s ease-out forwards; }
        .animate-delay-1 { animation-delay: 0.06s; opacity: 0; }
        .animate-delay-2 { animation-delay: 0.12s; opacity: 0; }
        .animate-delay-3 { animation-delay: 0.18s; opacity: 0; }
        .animate-delay-4 { animation-delay: 0.24s; opacity: 0; }
    </style>
</head>
<body class="bg-slate-50 dark:bg-[#09090B] min-h-screen text-slate-900 dark:text-white transition-colors duration-300" x-data="dashboardState()">

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         SECTION I â€” FIXED GLASSMORPHISM GLOBAL HEADER
         â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    <header x-data="{ accountOpen: false, searchFocused: false, mobileMenuOpen: false }"
            class="sticky top-0 z-50 w-full backdrop-blur-md bg-white/70 dark:bg-[#09090B]/80 border-b border-slate-200/80 dark:border-slate-800"
            id="global-header">
        <div class="max-w-[1440px] mx-auto px-6 py-3 flex items-center justify-between">

            <!-- â”€â”€ LEFT BLOCK: BRAND LOGO & CORE ROUTING LINKS â”€â”€ -->
            <div class="flex items-center space-x-8">
                <div class="relative flex items-center" x-data="{ orgOpen: false }">
                    <button @click="orgOpen = !orgOpen" class="flex items-center space-x-2 cursor-pointer group focus:outline-none" id="brand-logo">
                        <div class="h-7 w-7 bg-blue-600 rounded-lg flex items-center justify-center shadow-sm shadow-blue-500/20 group-hover:shadow-blue-500/30 transition-shadow duration-300">
                            <span class="text-white text-xs font-black font-mono tracking-tighter">G</span>
                        </div>
                        <span class="text-[15px] font-extrabold tracking-tight text-slate-900 dark:text-white"><%= organization ? organization.name : 'Growth-OS' %></span>
                        <svg class="h-4 w-4 text-slate-400 group-hover:text-slate-600 dark:group-hover:text-slate-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div x-show="orgOpen" @click.away="orgOpen = false" x-cloak
                         class="absolute left-0 top-full mt-2 w-64 bg-white dark:bg-[#111827] border border-slate-200 dark:border-slate-700 rounded-xl shadow-lg z-50 py-1">
                        <% if (typeof organizations !== 'undefined' && organizations.length > 0) { %>
                            <% organizations.forEach(function(org) { %>
                                <a href="javascript:void(0)" @click="switchOrganization(<%= org.id %>)"
                                   class="block px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800">
                                    <%= org.name %>
                                </a>
                            <% }); %>
                        <% } else { %>
