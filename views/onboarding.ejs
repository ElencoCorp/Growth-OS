<!-- Onboarding Content -->
<div x-show="currentTab === 'onboarding'" style="display: none;" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
    <div class="flex justify-between items-center mb-5">
        <h2 class="text-xl font-bold text-slate-100">Bulk Onboarding</h2>
        <button @click="importSelectedLocations()" :disabled="selectedLocations.length === 0 || isImporting" class="px-4 py-1.5 bg-blue-600 hover:bg-blue-500 text-white rounded-full text-xs font-semibold transition-colors disabled:opacity-50 flex items-center gap-2">
            <svg x-show="isImporting" class="w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
            <span x-text="isImporting ? 'Importing...' : 'Import Selected (' + selectedLocations.length + ')'"></span>
        </button>
    </div>

    <div class="bg-white/5 backdrop-blur-md rounded-2xl border border-white/10 shadow-xl overflow-hidden mb-6">
        <div class="p-4 border-b border-white/10 flex justify-between items-center bg-slate-900/50">
            <div class="flex items-center gap-3">
                <input type="checkbox" @change="toggleAllLocations($event)" :checked="accountLocations.length > 0 && selectedLocations.length === accountLocations.length" class="w-4 h-4 rounded border-slate-700 bg-slate-800 text-blue-500 focus:ring-blue-500 focus:ring-offset-slate-900">
                <span class="text-sm font-semibold text-slate-300">Select All Available</span>
            </div>
            <button @click="fetchAccountLocations()" class="text-xs text-blue-400 hover:text-blue-300 flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                Refresh List
            </button>
        </div>
        
        <template x-if="isLoadingLocations">
            <div class="p-8 text-center text-slate-400">
                <svg class="w-8 h-8 animate-spin mx-auto mb-3 text-blue-500" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                <p class="text-sm font-medium">Fetching associated Google locations...</p>
            </div>
        </template>
        
        <template x-if="!isLoadingLocations && accountLocations.length === 0">
            <div class="p-8 text-center text-slate-400">
                <p class="text-sm">No new locations found for this account.</p>
            </div>
        </template>

        <div class="max-h-96 overflow-y-auto" x-show="!isLoadingLocations && accountLocations.length > 0">
            <template x-for="loc in accountLocations" :key="loc.googlePlaceId">
                <label class="flex items-start gap-4 p-4 border-b border-white/5 hover:bg-white/[0.02] cursor-pointer transition-colors">
                    <div class="pt-1">
                        <input type="checkbox" :value="loc.googlePlaceId" x-model="selectedLocations" class="w-4 h-4 rounded border-slate-700 bg-slate-800 text-blue-500 focus:ring-blue-500 focus:ring-offset-slate-900">
                    </div>
                    <div class="flex-1">
                        <h3 class="font-bold text-sm text-slate-100 mb-0.5" x-text="loc.name"></h3>
                        <p class="text-xs text-slate-400 mb-1" x-text="loc.address || 'No address provided'"></p>
                        <div class="flex items-center gap-2">
                            <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-slate-800 text-slate-300 border border-slate-700" x-text="loc.categories"></span>
                            <span class="px-2 py-0.5 rounded text-[10px] font-bold border" :class="loc.googleVerificationStatus === 'VERIFIED' ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' : 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20'" x-text="loc.googleVerificationStatus"></span>
                        </div>
                    </div>
                </label>
            </template>
        </div>
    </div>
    
    <div x-show="importResults" class="bg-white/5 backdrop-blur-md rounded-2xl border border-white/10 p-5 mb-6">
        <h3 class="text-sm font-bold text-slate-100 mb-2">Import Results</h3>
        <p class="text-xs text-slate-400 mb-4" x-text="importResults?.message"></p>
        <div class="max-h-48 overflow-y-auto space-y-2">
            <template x-for="res in importResults?.results" :key="res.index">
                <div class="flex items-center gap-2 text-xs p-2 rounded bg-slate-900/50 border border-white/5">
                    <span x-show="res.success" class="text-emerald-400 font-bold">✓</span>
                    <span x-show="!res.success" class="text-rose-400 font-bold">✗</span>
                    <span class="font-semibold text-slate-300" x-text="res.name"></span>
                    <span x-show="!res.success" class="text-slate-500 italic" x-text="'- ' + res.error"></span>
                </div>
            </template>
        </div>
    </div>
</div>
