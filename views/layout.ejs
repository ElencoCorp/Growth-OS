                                </template>

                                <div x-show="post.status === 'DRAFT'" class="flex flex-col gap-3 mt-auto pt-2">
                                    <button @click="publishPost(post)" class="w-full bg-emerald-600/20 hover:bg-emerald-600/30 text-emerald-400 border border-emerald-500/30 py-3 rounded-xl font-bold text-xs uppercase tracking-wider transition-all flex items-center justify-center gap-2 shadow-lg">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                                        Publish Now
                                    </button>
                                    
                                    <div class="flex flex-col gap-2 bg-blue-900/10 border border-blue-500/20 rounded-xl p-3 shadow-md" x-data="{ selectedChannels: ['GBP'] }">
                                        <div class="mb-3 border-b border-slate-700/50 pb-3">
                                            <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest pl-1 block mb-2">Publish To Channels</label>
                                            <div class="flex items-center gap-4 px-1">
                                                <label class="flex items-center gap-2 cursor-pointer group">
                                                    <input type="checkbox" value="GBP" x-model="selectedChannels" class="w-4 h-4 rounded border-slate-600 text-blue-500 focus:ring-blue-500 focus:ring-offset-slate-900 bg-slate-800">
                                                    <span class="text-xs font-bold text-slate-300 group-hover:text-white transition-colors">Google Profile</span>
                                                </label>
                                                <label class="flex items-center gap-2 cursor-pointer group" :class="!metaStatus?.facebookPageId ? 'opacity-50 cursor-not-allowed' : ''">
                                                    <input type="checkbox" value="FB" x-model="selectedChannels" :disabled="!metaStatus?.facebookPageId" class="w-4 h-4 rounded border-slate-600 text-blue-500 focus:ring-blue-500 focus:ring-offset-slate-900 bg-slate-800">
                                                    <span class="text-xs font-bold text-slate-300 group-hover:text-white transition-colors">Facebook</span>
                                                </label>
                                                <label class="flex items-center gap-2 cursor-pointer group" :class="!metaStatus?.instagramAccountId ? 'opacity-50 cursor-not-allowed' : ''">
                                                    <input type="checkbox" value="IG" x-model="selectedChannels" :disabled="!metaStatus?.instagramAccountId" class="w-4 h-4 rounded border-slate-600 text-blue-500 focus:ring-blue-500 focus:ring-offset-slate-900 bg-slate-800">
                                                    <span class="text-xs font-bold text-slate-300 group-hover:text-white transition-colors">Instagram</span>
                                                </label>
                                            </div>
                                        </div>

                                        <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest pl-1">Select Publication Date/Time</label>
                                        <div class="flex items-center gap-2">
                                            
                                            <!-- Custom Date/Time Picker -->
                                            <div x-data="{
                                                showPicker: false,
                                                month: new Date().getMonth(),
                                                year: new Date().getFullYear(),
                                                day: new Date().getDate(),
                                                time: '12:00',
                                                get days() {
                                                    let daysArray = [];
                                                    let firstDay = new Date(this.year, this.month, 1).getDay();
                                                    let daysInMonth = new Date(this.year, this.month + 1, 0).getDate();
                                                    for(let i=0; i<firstDay; i++) daysArray.push('');
                                                    for(let i=1; i<=daysInMonth; i++) daysArray.push(i);
                                                    return daysArray;
                                                },
                                                get monthName() {
                                                    return new Date(this.year, this.month).toLocaleString('default', { month: 'long' });
                                                },
                                                prevMonth() {
                                                    if(this.month === 0) { this.month = 11; this.year--; }
                                                    else { this.month--; }
                                                },
                                                nextMonth() {
                                                    if(this.month === 11) { this.month = 0; this.year++; }
                                                    else { this.month++; }
                                                },
                                                setDate(d) {
                                                    if(!d) return;
                                                    this.day = d;
                                                    this.updateModel();
                                                },
                                                updateModel() {
                                                    let m = String(this.month + 1).padStart(2, '0');
                                                    let d = String(this.day).padStart(2, '0');
                                                    post.scheduleDate = `${this.year}-${m}-${d}T${this.time}`;
                                                },
                                                formatDisplay() {
                                                    if(!post.scheduleDate) return 'Select Date/Time';
                                                    let d = new Date(post.scheduleDate);
                                                    if(isNaN(d.getTime())) return 'Select Date/Time';
                                                    return d.toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' });
                                                }
                                            }" class="relative w-full">
                                                
                                                <button type="button" @click="showPicker = !showPicker" class="w-full text-left bg-black/50 text-slate-200 text-sm rounded-lg border border-slate-700 px-3 py-2.5 focus:outline-none hover:bg-black/60 transition-all font-['Plus_Jakarta_Sans'] flex justify-between items-center shadow-inner">
                                                    <span x-text="formatDisplay()"></span>
                                                    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                                </button>
                                                
                                                <div x-show="showPicker" @click.away="showPicker = false" class="absolute z-50 bottom-full left-0 mb-2 w-72 bg-slate-900/95 backdrop-blur-2xl border border-slate-700 rounded-2xl shadow-2xl p-4 font-['Plus_Jakarta_Sans']" style="display: none;" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-2 scale-95" x-transition:enter-end="opacity-100 translate-y-0 scale-100" x-transition:leave="transition ease-in duration-100" x-transition:leave-start="opacity-100 translate-y-0 scale-100" x-transition:leave-end="opacity-0 translate-y-2 scale-95">
                                                    
                                                    <div class="flex justify-between items-center mb-4">
                                                        <button type="button" @click="prevMonth()" class="p-1.5 rounded-lg hover:bg-slate-800 text-slate-300 transition-colors">
                                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                                                        </button>
                                                        <div class="font-bold text-slate-100 text-sm tracking-wide" x-text="monthName + ' ' + year"></div>
                                                        <button type="button" @click="nextMonth()" class="p-1.5 rounded-lg hover:bg-slate-800 text-slate-300 transition-colors">
                                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                                        </button>
                                                    </div>
                                                    
                                                    <div class="grid grid-cols-7 gap-1 mb-2 text-center text-[10px] font-bold text-slate-500 uppercase tracking-wider">
                                                        <div>Su</div><div>Mo</div><div>Tu</div><div>We</div><div>Th</div><div>Fr</div><div>Sa</div>
                                                    </div>
                                                    
                                                    <div class="grid grid-cols-7 gap-1 text-sm">
                                                        <template x-for="(d, i) in days" :key="i">
                                                            <button type="button" 
                                                                    @click="setDate(d)" 
                                                                    :disabled="!d" 
                                                                    class="h-8 rounded-lg flex items-center justify-center transition-all"
                                                                    :class="{'hover:bg-slate-800 text-slate-300': d && d !== day, 'bg-blue-600 text-white font-bold shadow-md ring-2 ring-blue-500/50': d === day, 'invisible': !d}">
                                                                <span x-text="d"></span>
                                                            </button>
                                                        </template>
                                                    </div>
                                                    
                                                    <div class="mt-4 pt-4 border-t border-slate-700/50 flex items-center justify-between">
                                                        <label class="text-xs font-bold text-slate-400 uppercase tracking-widest">Time</label>
                                                        <input type="time" x-model="time" @change="updateModel()" class="bg-black/50 text-slate-200 text-sm rounded-lg border border-slate-700 px-3 py-1.5 focus:outline-none focus:ring-1 focus:ring-blue-500">
                                                    </div>
                                                    
                                                    <button type="button" @click="showPicker = false" class="mt-4 w-full bg-blue-600/20 hover:bg-blue-600/30 text-blue-400 border border-blue-500/30 py-2 rounded-lg font-bold text-xs uppercase tracking-wider transition-all">
                                                        Confirm Date
                                                    </button>
                                                </div>
                                            </div>

                                            <button @click="schedulePost(post, selectedChannels)" class="bg-blue-600/20 hover:bg-blue-600/30 text-blue-400 border border-blue-500/30 px-5 py-2.5 rounded-lg font-bold text-xs uppercase tracking-wider transition-all whitespace-nowrap shadow-sm h-full">
                                                Schedule
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- RIGHT COLUMN: Visual Live Mock Preview -->
                            <div class="flex items-center justify-center bg-black/10 rounded-2xl p-4 border border-white/5">
                                <template x-if="post.imageUrl">
                                    <div class="w-full rounded-xl overflow-hidden shadow-2xl border border-white/10 cursor-pointer group relative aspect-video" @click="activeLightboxImage = post.imageUrl">
                                        <img :src="post.imageUrl" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" alt="Generated Banner" />
                                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center pb-4">
                                            <span class="text-white text-xs font-bold uppercase tracking-widest bg-black/50 px-3 py-1 rounded-full backdrop-blur-sm border border-white/20">Click to View</span>
                                        </div>
                                    </div>
                                </template>
                                <template x-if="!post.imageUrl">
                                    <div class="w-full aspect-video rounded-xl bg-slate-800/50 flex flex-col items-center justify-center text-slate-500 border border-slate-700/50">
                                        <svg class="w-10 h-10 mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                        <span class="text-xs uppercase tracking-wider font-bold opacity-75">No Image Available</span>
                                    </div>
                                </template>
                            </div>
                        </div>

                    </div>
                </template>
            </div>
        </div>
        
        <!-- Calendar Content -->
        <div x-show="currentTab === 'calendar'" style="display: none;" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0" class="pb-24">
            <h2 class="text-xl font-bold mb-4 text-slate-100 flex items-center gap-2">
                <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                Content Calendar
            </h2>
            
            <template x-if="calendarPosts && calendarPosts.length > 0">
                <div class="space-y-4">
                    <template x-for="post in calendarPosts" :key="post.id">
                        <div class="bg-slate-900/50 rounded-xl p-4 border border-white/5 flex flex-col gap-2 relative shadow-lg group hover:border-white/10 transition-colors">
                            <div class="flex items-center gap-2 mb-2">
                                <span x-show="post.status === 'PUBLISHED'" class="text-[10px] bg-emerald-500/20 text-emerald-400 px-2 py-0.5 rounded font-bold uppercase tracking-widest border border-emerald-500/20">Published</span>
                                <span x-show="post.status === 'SCHEDULED'" class="text-[10px] bg-blue-500/20 text-blue-400 px-2 py-0.5 rounded font-bold uppercase tracking-widest border border-blue-500/20">Scheduled</span>
                                <span x-show="post.status === 'FAILED'" class="text-[10px] bg-red-500/20 text-red-400 px-2 py-0.5 rounded font-bold uppercase tracking-widest border border-red-500/20">Failed</span>
                                <span x-show="post.status === 'DRAFT'" class="text-[10px] bg-slate-500/20 text-slate-400 px-2 py-0.5 rounded font-bold uppercase tracking-widest border border-slate-500/20">Draft</span>
                                <span class="text-xs font-bold text-slate-400 ml-auto" x-text="post.scheduledFor ? new Date(post.scheduledFor).toLocaleString() : (post.publishedAt ? new Date(post.publishedAt).toLocaleString() : 'No date')"></span>
                            </div>
                            <div class="text-slate-200 text-sm leading-relaxed whitespace-pre-wrap bg-black/20 p-4 rounded-xl border border-white/5 flex-grow font-['Plus_Jakarta_Sans'] line-clamp-3" x-text="post.textContent"></div>
                            
                            <template x-if="post.errorMessage">
