<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= title %></title>
    <!-- Google Fonts: Plus Jakarta Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Tailwind CSS (compiled locally) -->
    <link href="/public/output.css" rel="stylesheet">
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        body {
            /* Prevent pull-to-refresh on mobile */
            overscroll-behavior-y: contain;
        }
    </style>
</head>
<body class="bg-slate-950 text-slate-200 font-sans antialiased h-screen overflow-hidden selection:bg-blue-500/30" x-data="appData()" x-init="initData()">

    <!-- LOGIN SCREEN OVERLAY -->
    <div x-show="!isLoggedIn" style="display: none;" class="fixed inset-0 z-[100] bg-slate-950 flex flex-col items-center justify-center p-4">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-900/20 to-purple-900/20 pointer-events-none"></div>
        <div class="absolute top-0 right-0 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl -mr-20 -mt-20"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-purple-500/10 rounded-full blur-3xl -ml-20 -mb-20"></div>
        
        <div class="w-full max-w-sm bg-slate-900/80 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl relative z-10">
            <div class="flex items-center justify-center mb-8">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-xl font-bold text-white shadow-lg shadow-blue-500/25 border border-white/20">G</div>
            </div>
            
            <h1 class="text-2xl font-bold text-center text-white mb-2 font-['Plus_Jakarta_Sans']">Welcome Back</h1>
            <p class="text-sm text-center text-slate-400 mb-8">Sign in to your Growth OS dashboard.</p>
            
            <form @submit.prevent="login()" class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5 pl-1">Email Address</label>
                    <input type="email" x-model="loginEmail" required class="w-full bg-black/50 border border-slate-700/50 rounded-xl text-slate-200 px-4 py-3 text-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 focus:outline-none transition-all placeholder-slate-600 font-['Plus_Jakarta_Sans']" placeholder="admin@growthos.com">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5 pl-1">Password</label>
                    <input type="password" x-model="loginPassword" required class="w-full bg-black/50 border border-slate-700/50 rounded-xl text-slate-200 px-4 py-3 text-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 focus:outline-none transition-all placeholder-slate-600 font-['Plus_Jakarta_Sans']" placeholder="••••••••">
                </div>
                
                <div x-show="loginError" class="text-red-400 text-xs font-bold text-center bg-red-900/20 py-2 rounded-lg border border-red-500/20" x-text="loginError" style="display: none;"></div>
                
                <button type="submit" :disabled="isLoggingIn" class="w-full bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-500 hover:to-purple-500 text-white py-3.5 rounded-xl font-bold text-sm transition-all shadow-lg shadow-blue-500/25 flex items-center justify-center gap-2 mt-4 font-['Plus_Jakarta_Sans']">
                    <span x-show="!isLoggingIn">Sign In</span>
                    <span x-show="isLoggingIn" class="flex items-center gap-2">
                        <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        Authenticating...
                    </span>
                </button>
            </form>
        </div>
    </div>

    <!-- AUTHENTICATED APP CONTAINER -->
    <div x-show="isLoggedIn && locations.length > 0" x-cloak class="h-full flex flex-col">
        <!-- Header -->
        <header class="bg-white/5 backdrop-blur-md border-b border-white/10 sticky top-0 z-50 h-16 shrink-0">
            <div class="px-4 py-3 flex justify-between items-center">
                <div class="flex-1 mr-4 relative flex items-center gap-2">
                    <div class="flex-1 relative" x-data="{ orgOpen: false }">
                        <button @click="orgOpen = !orgOpen" class="w-full bg-white/5 border border-white/10 text-slate-100 text-sm rounded-xl focus:ring-purple-500 focus:border-purple-500 flex justify-between items-center p-3 backdrop-blur-md font-semibold cursor-pointer shadow-sm">
                            <span x-text="organizations.find(o => o.id == orgId)?.name || 'Select Organization'"></span>
                            <svg class="w-4 h-4 text-slate-400 transition-transform duration-200" :class="orgOpen ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </button>
                        <div x-show="orgOpen" @click.away="orgOpen = false" class="absolute z-50 left-0 mt-2 w-full bg-slate-900/95 backdrop-blur-xl border border-white/10 rounded-xl shadow-2xl overflow-hidden" x-transition style="display: none;">
                            <div class="max-h-64 overflow-y-auto">
                                <template x-for="org in organizations" :key="org.id">
                                    <div @click="orgId = org.id; fetchLocations(); orgOpen = false" class="px-4 py-3 hover:bg-white/10 cursor-pointer text-sm font-medium text-slate-200 transition-colors border-b border-white/5 last:border-0" :class="orgId == org.id ? 'bg-purple-500/10 text-purple-400' : ''">
                                        <span x-text="org.name"></span>
                                    </div>
                                </template>
                            </div>
                        </div>
                    </div>

                    <div class="flex-1 relative" x-data="{ open: false }">
                        <button @click="open = !open" class="w-full bg-white/5 border border-white/10 text-slate-100 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 flex justify-between items-center p-3 backdrop-blur-md font-semibold cursor-pointer shadow-sm" :disabled="!orgId" :class="!orgId ? 'opacity-50 cursor-not-allowed' : ''">
                            <span x-text="locations.find(l => l.id == profileId)?.name || 'Select Location'"></span>
                            <svg class="w-4 h-4 text-slate-400 transition-transform duration-200" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </button>
                    
                    <div x-show="open" @click.away="open = false" class="absolute z-50 left-0 mt-2 w-full bg-slate-900/95 backdrop-blur-xl border border-white/10 rounded-xl shadow-2xl overflow-hidden" x-transition:enter="transition ease-out duration-100" x-transition:enter-start="opacity-0 translate-y-1" x-transition:enter-end="opacity-100 translate-y-0" style="display: none;">
                        <div class="max-h-64 overflow-y-auto">
                            <template x-for="loc in locations" :key="loc.id">
                                <div @click="profileId = loc.id; switchTenant(); open = false" class="px-4 py-3 hover:bg-white/10 cursor-pointer text-sm font-medium text-slate-200 transition-colors border-b border-white/5 last:border-0" :class="profileId == loc.id ? 'bg-blue-500/10 text-blue-400' : ''">
                                    <span x-text="loc.name"></span>
                                    <span class="block text-[10px] text-slate-400 mt-0.5" x-show="loc.categories" x-text="loc.categories"></span>
                                </div>
                            </template>
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <div class="px-3 py-1 rounded-full bg-white/5 border border-white/10 flex items-center gap-1.5">
                        <span class="text-xs text-slate-400 font-medium">Score</span>
                        <span x-text="score" class="text-sm font-bold text-blue-400 drop-shadow-sm"></span>
                    </div>
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-sm font-bold text-white shadow-lg shadow-indigo-500/20 border border-white/20 cursor-pointer relative" @click="showUserMenu = !showUserMenu">
                        <span x-text="userRole === 'Administrator' ? 'A' : 'C'"></span>
                        
                        <!-- User Dropdown Menu -->
                        <div x-show="showUserMenu" @click.away="showUserMenu = false" class="absolute top-full right-0 mt-2 w-48 bg-slate-900/95 backdrop-blur-xl border border-white/10 rounded-xl shadow-2xl overflow-hidden" style="display: none;">
                            <div class="px-4 py-3 border-b border-white/5 bg-black/20">
                                <p class="text-xs text-slate-400">Signed in as</p>
                                <p class="text-sm font-bold text-white truncate" x-text="userEmail"></p>
                                <p class="text-[10px] font-bold text-blue-400 uppercase tracking-widest mt-1" x-text="userRole"></p>
                            </div>
                            <button @click="logout()" class="w-full text-left px-4 py-3 text-sm text-red-400 hover:bg-white/5 transition-colors font-semibold flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                                Sign Out
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </header>

    <!-- Main Content Area -->
    <main class="p-4 space-y-4 h-[calc(100vh-8rem)] overflow-y-auto pb-24">
        <!-- Dashboard Content -->
        <div x-show="currentTab === 'home'" style="display: none;" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
            <div class="bg-white/5 backdrop-blur-md rounded-2xl shadow-xl border border-white/10 p-5 relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl -mr-10 -mt-10"></div>
                <h2 class="text-lg font-bold mb-3 text-slate-100">Today's Actions</h2>
                <div class="space-y-3 relative z-10">
                    <template x-if="actions.length === 0">
                        <div class="text-center py-6">
                            <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center mx-auto mb-3 border border-white/5">
                                <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            </div>
                            <p class="text-sm text-slate-400 font-medium">You are all caught up!</p>
                        </div>
                    </template>
                    <template x-for="(action, index) in actions" :key="action.title">
                        <div @click="openTaskModal(action.title)" class="p-4 bg-blue-500/10 hover:bg-blue-500/20 cursor-pointer transition-all duration-200 rounded-xl border border-blue-500/20 flex items-start gap-3 group">
                            <div class="w-7 h-7 rounded-full bg-blue-500/20 flex-shrink-0 flex items-center justify-center text-xs font-bold text-blue-300 group-hover:bg-blue-500/30 transition-colors border border-blue-500/30" x-text="index + 1"></div>
                            <div>
                                <p class="font-semibold text-sm text-blue-100 mb-0.5" x-text="action.title"></p>
                                <p class="text-xs text-blue-300/80 leading-relaxed" x-text="action.description"></p>
                            </div>
                        </div>
                    </template>
                </div>
            </div>
            
            <div class="mt-4 bg-white/5 backdrop-blur-md rounded-2xl shadow-xl border border-white/10 p-5">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-lg font-bold text-slate-100 flex items-center gap-2">
                        <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                        Competitor Intelligence Radar
                    </h2>
                    <button @click="syncRankings()" :disabled="loadingSeo" class="bg-purple-600/50 hover:bg-purple-600 text-white px-3 py-1.5 rounded-lg text-xs font-bold transition-all flex items-center gap-2 border border-purple-500/30">
                        <svg class="w-4 h-4" :class="{'animate-spin': loadingSeo}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                        Sync
                    </button>
                </div>
                
                <div class="flex gap-2 mb-4">
                    <input type="text" x-model="newKeyword" @keydown.enter="addKeyword()" placeholder="Enter keyword to track..." class="flex-1 bg-slate-900/50 border border-white/10 rounded-lg px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-purple-500/50">
                    <button @click="addKeyword()" :disabled="!newKeyword" class="bg-emerald-600/50 hover:bg-emerald-600 disabled:opacity-50 text-white px-4 py-2 rounded-lg text-sm font-bold transition-all border border-emerald-500/30">
                        + Add
                    </button>
                </div>
                
                <template x-if="trackedKeywords && trackedKeywords.length > 0">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <template x-for="kw in trackedKeywords" :key="kw.id">
                            <div class="bg-slate-900/50 rounded-xl p-4 border border-white/5 flex flex-col">
                                <div class="flex justify-between items-center mb-2">
                                    <h3 class="font-bold text-sm text-slate-200 truncate" x-text="kw.term"></h3>
                                    <span class="px-2 py-0.5 rounded-full text-[10px] font-bold" :class="kw.rank <= 3 ? 'bg-emerald-500/20 text-emerald-400' : (kw.rank <= 10 ? 'bg-yellow-500/20 text-yellow-400' : 'bg-slate-700 text-slate-400')" x-text="kw.rank ? 'Rank: ' + kw.rank : 'Unranked'"></span>
                                </div>
                                <div class="text-xs text-slate-400 mb-1">
                                    <span class="font-semibold text-slate-500">Top Competitors:</span>
                                </div>
                                <div class="text-xs text-slate-300 line-clamp-2" x-text="kw.topCompetitors || 'No data yet.'"></div>
                            </div>
                        </template>
                    </div>
                </template>
                <template x-if="!trackedKeywords || trackedKeywords.length === 0">
                    <div class="text-center py-6 text-slate-400 text-sm">
                        No keywords tracked. Add one above to begin.
                    </div>
                </template>
            </div>
            
            <div class="mt-4 bg-white/5 backdrop-blur-md rounded-2xl shadow-xl border border-white/10 p-5">
                <h2 class="text-lg font-bold mb-2 text-slate-100">Recent Reviews</h2>
                <div class="text-center py-8 text-slate-400 text-sm">
                    Switch to the Reviews tab to sync and manage reviews.
                </div>
            </div>
        </div>
        
        <!-- Reviews Content -->
        <div x-show="currentTab === 'reviews'" style="display: none;" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
            <div class="flex justify-between items-center mb-5">
                <h2 class="text-xl font-bold text-slate-100">Manage Reviews</h2>
                <button @click="syncReviews()" :disabled="isSyncing" class="px-4 py-1.5 bg-white/10 hover:bg-white/20 text-slate-200 rounded-full text-xs font-semibold transition-colors border border-white/10 flex items-center gap-1.5 disabled:opacity-50">
                    <svg x-show="!isSyncing" class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                    <svg x-show="isSyncing" class="w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
                    <span x-text="isSyncing ? 'Syncing...' : 'Sync Live'"></span>
                </button>
            </div>
            <div class="space-y-4">
                <template x-if="reviews.length === 0">
                    <div class="bg-white/5 backdrop-blur-md rounded-2xl border border-white/10 p-6">
                        <div class="flex flex-col items-center justify-center py-8 text-slate-400">
                            <div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center mb-4 border border-white/5">
                                <svg class="w-8 h-8 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                            </div>
                            <p class="text-sm font-medium">No reviews found.</p>
                        </div>
                    </div>
                </template>
                
                <template x-for="review in reviews" :key="review.id">
                    <div class="bg-white/5 backdrop-blur-md rounded-2xl shadow-xl border border-white/10 p-5 transition-all hover:bg-white/[0.07]">
                        <div class="flex justify-between items-start mb-3">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-slate-700 to-slate-800 flex items-center justify-center text-xs font-bold text-slate-300 border border-slate-600" x-text="review.authorName.charAt(0)"></div>
                                <h3 class="font-bold text-sm text-slate-100" x-text="review.authorName"></h3>
                            </div>
                            <div class="flex gap-0.5 text-yellow-400 drop-shadow-[0_0_2px_rgba(250,204,21,0.5)]">
                                <template x-for="i in review.rating">
                                    <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                                </template>
                            </div>
                        </div>
                        <p class="text-slate-300 text-sm mb-4 leading-relaxed" x-text="review.text"></p>
                        
                        <div class="border-t border-white/10 pt-4 mt-2">
                            <template x-if="!review.publishedReply && !review.aiSuggestedReply">
                                <button @click="generateAiReply(review.id)" class="w-full bg-indigo-500/10 hover:bg-indigo-500/20 text-indigo-300 border border-indigo-500/20 font-semibold py-2.5 px-4 rounded-xl text-sm transition-all flex items-center justify-center gap-2 group">
                                    <svg x-show="generatingReply[review.id]" class="animate-spin h-4 w-4 text-indigo-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                                    <span x-show="generatingReply[review.id]">Processing AI Reply...</span>
                                    <template x-if="!generatingReply[review.id]">
                                        <div class="flex items-center gap-2">
                                            <svg class="w-4 h-4 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                                            Generate AI Reply
                                        </div>
                                    </template>
                                </button>
                            </template>
                            
                            <template x-if="review.aiSuggestedReply && !review.publishedReply">
                                <div class="bg-indigo-900/20 rounded-xl p-4 border border-indigo-500/20 relative">
                                    <div class="flex items-center justify-between mb-2">
                                        <div class="flex items-center gap-1.5">
                                            <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                                            <p class="text-xs font-bold text-indigo-300 uppercase tracking-wider">AI Suggested Reply</p>
                                        </div>
                                    </div>
                                    <textarea x-model="review.aiSuggestedReply" class="w-full bg-slate-900/50 text-sm text-slate-200 p-3 rounded-lg border border-white/5 focus:border-indigo-500/50 focus:ring-1 focus:ring-indigo-500/50 transition-all mb-3 resize-none h-24" placeholder="Edit the suggested reply..."></textarea>
                                    <button @click="publishAiReply(review.id, review.aiSuggestedReply)" :disabled="publishingReply[review.id]" class="w-full bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded-lg text-sm transition-all flex items-center justify-center gap-2 disabled:opacity-50">
                                        <svg x-show="publishingReply[review.id]" class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                                        <span x-text="publishingReply[review.id] ? 'Publishing...' : 'Publish to Google'"></span>
                                    </button>
                                </div>
                            </template>

                            <template x-if="review.publishedReply || review.reply">
