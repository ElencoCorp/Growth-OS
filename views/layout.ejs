                            <div class="flex flex-col gap-4 h-full">
                                <template x-if="post.status === 'DRAFT'">
                                    <textarea x-model="post.textContent" rows="8" class="w-full bg-black/40 border border-slate-700/50 rounded-xl text-slate-200 p-4 text-sm focus:ring-1 focus:ring-blue-500 focus:outline-none transition-all resize-none shadow-inner flex-grow font-['Plus_Jakarta_Sans'] leading-relaxed"></textarea>
                                </template>
                                <template x-if="post.status !== 'DRAFT'">
