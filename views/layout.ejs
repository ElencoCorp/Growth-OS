    <!-- Lightbox Modal -->
    <div x-show="activeLightboxImage !== null" class="fixed inset-0 z-[200] flex items-center justify-center bg-black/90 backdrop-blur-xl" style="display: none;" x-transition.opacity>
        <button @click="activeLightboxImage = null" class="absolute top-6 right-6 p-2 rounded-full bg-white/10 hover:bg-white/20 text-white border border-white/20 shadow-xl transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
        <div class="max-w-4xl max-h-[85vh] p-4 flex items-center justify-center">
            <img :src="activeLightboxImage" @click.stop class="max-w-full max-h-[80vh] rounded-xl shadow-2xl object-contain border border-white/10" alt="Fullscreen generated post image">
        </div>
    </div>

    <!-- Support safe area for modern mobile devices -->
    <style>
        .pb-safe { padding-bottom: calc(env(safe-area-inset-bottom) + 8rem); }
    </style>

    <!-- App Logic -->
    <script>
        const originalFetch = window.fetch;
        window.fetch = async (url, options = {}) => {
            const { timeout = 8000, ...fetchOptions } = options;
            const controller = new AbortController();
            const id = setTimeout(() => controller.abort(), timeout);
            try {
                const response = await originalFetch(url, { ...fetchOptions, signal: controller.signal });
                clearTimeout(id);
                return response;
            } catch (err) {
                clearTimeout(id);
                throw err;
            }
        };

        function appData() {
            return {
                isLoggedIn: false,
                isLoggingIn: false,
                loginEmail: '',
                loginPassword: '',
                loginError: '',
                userRole: '',
                userEmail: '',
                showUserMenu: false,
                currentTab: 'home',
                showModal: false,
                activeTask: '',
                taskInput: '',
                isSubmitting: false,
                isGeneratingDesc: false,
                isResetting: false,
                isSimulating: false,
                isExporting: false,
                isCreatingProfile: false,
                newProfileName: '',
                newProfileCategory: '',
                activeLightboxImage: null,
                organizations: [],
                orgId: null,
                profileId: null,
                locations: [],
                actions: [],
                reviews: [],
                posts: [],
                calendarPosts: [],
                metaStatus: null,
                reports: [],
                generatingReport: false,
                whiteLabel: { agencyName: 'Growth-OS', primaryColor: '#3b82f6' },
                loadingAnalytics: false,
                isGeneratingPost: false,
                postGoal: '',
                metrics: null,
                executiveSummary: '',
                loadingSeo: false,
                competitors: [],
                trackedKeywords: [],
                newKeyword: '',
                score: 100,
                generatingReply: {},
                publishingReply: {},
                hoursData: {
                    days: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri'],
                    open: '09:00 AM',
                    close: '05:00 PM'
                },
                
                formatSummary(text) {
                    if (!text) return '';
                    // Simple formatting for bolding text before colon, etc.
                    return text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
                },

                async fetchOrganizations() {
                    try {
                        const res = await fetch('/api/v1/organizations');
                        const data = await res.json();
                        if (data.success) {
                            this.organizations = data.organizations;
                            if (this.organizations.length > 0 && !this.orgId) {
                                this.orgId = this.organizations[0].id;
                                const org = this.organizations[0];
                                if (org.whiteLabelSettings) {
                                    try {
                                        this.whiteLabel = { ...this.whiteLabel, ...JSON.parse(org.whiteLabelSettings) };
                                    } catch(e) {}
                                }
                            }
                        }
                    } catch (e) {
                        console.error('Failed to fetch orgs', e);
                    }
                },

                async initData() {
                    try {
                        const authRes = await fetch('/api/v1/auth/me');
                        if (authRes.ok) {
                            const data = await authRes.json();
                            this.userEmail = data.user.email;
                            this.userRole = data.user.role;
                            this.isLoggedIn = true;
                            
                            await this.loadApp();
                        } else {
                            this.isLoggedIn = false;
                        }
                    } catch (e) {
                        this.isLoggedIn = false;
                    }
                },
                
                async loadApp() {
                    await this.fetchOrganizations();
                    await this.fetchLocations();
                    if (this.locations.length > 0) {
                        this.profileId = this.locations[0].id;
                        this.fetchReviews();
                        this.fetchPosts();
                        this.fetchCalendar();
                        this.fetchMetaStatus();
                        this.fetchAnalytics();
                        this.fetchSeoData();
                    }
                    
                    // Auto-poll for reviews every 5 seconds
                    setInterval(() => {
                        this.fetchReviews();
                    }, 5000);
                },

                async login() {
                    this.loginError = '';
                    this.isLoggingIn = true;
                    try {
                        const res = await fetch('/api/v1/auth/login', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ email: this.loginEmail, password: this.loginPassword })
                        });
                        const data = await res.json();
                        if (res.ok && data.success) {
                            this.userEmail = data.user.email;
                            this.userRole = data.user.role;
                            this.isLoggedIn = true;
                            this.loginPassword = '';
                            await this.loadApp();
                        } else {
                            this.loginError = data.error || 'Invalid login details';
                        }
                    } catch(e) {
                        this.loginError = 'Connection failed';
                    } finally {
                        this.isLoggingIn = false;
                    }
                },

                async logout() {
                    try {
                        await fetch('/api/v1/auth/logout', { method: 'POST' });
                    } catch(e) {}
                    this.isLoggedIn = false;
                    this.userEmail = '';
                    this.userRole = '';
                    this.showUserMenu = false;
                },

                async fetchLocations() {
                    if (!this.orgId) return;
                    try {
                        const res = await fetch(`/api/v1/mock-gbp/locations?organizationId=${this.orgId}`);
                        const data = await res.json();
                        if (data.locations) {
                            this.locations = data.locations;
                            if (this.locations.length > 0) {
                                this.profileId = this.locations[0].id;
                                this.switchTenant();
                            } else {
                                this.profileId = null;
                            }
                        }
                    } catch (e) {
                        console.error('Failed to fetch locations:', e);
                    }
                },

                async switchTenant() {
                    // Instantly clear active screen state
                    this.actions = [];
                    this.reviews = [];
                    this.posts = [];
                    this.metrics = null;
                    this.executiveSummary = '';
                    this.competitors = [];
                    this.score = '-';
                    // Fetch new tenant data
                    await this.fetchProfile();
                    await this.fetchReviews();
                    await this.fetchPosts();
                    await this.fetchCalendar();
                    await this.fetchMetaStatus();
                    await this.fetchAnalytics();
                    await this.fetchSeoData();
                },

                async fetchAnalytics() {
                    if (!this.profileId) return;
                    this.loadingAnalytics = true;
                    try {
                        const res = await fetch(`/api/v1/analytics/${this.profileId}`);
                        if (res.ok) {
                            const data = await res.json();
                            this.score = data.healthScore || 0;
                            this.executiveSummary = data.executiveSummary;
                            if (data.snapshots && data.snapshots.length > 0) {
                                this.metrics = data.snapshots[0]; // Latest snapshot
                            } else {
                                this.metrics = { profileViews: 0, searchQueries: 0, interactions: 0 };
                            }
                        }
                    } catch (e) {
                        console.error('Fetch analytics failed', e);
                    } finally {
                        this.loadingAnalytics = false;
                    }
                },
                
                async syncInsights() {
                    if (!this.profileId) return;
                    this.loadingAnalytics = true;
                    try {
                        const res = await fetch(`/api/v1/sync/insights/${this.profileId}`, { method: 'POST' });
                        if (res.ok) {
                            // Give the background job 2 seconds to complete before polling
                            setTimeout(() => {
                                this.fetchAnalytics();
                            }, 2000);
                        } else {
                            alert('Failed to sync insights');
                            this.loadingAnalytics = false;
                        }
                    } catch (e) {
                        console.error('Sync insights failed', e);
                        this.loadingAnalytics = false;
                    }
                },
                  async fetchSeoData() {
                    if (!this.profileId) return;
                    this.loadingSeo = true;
                    try {
                        const res = await fetch(`/api/v1/seo/radar?locationId=${this.profileId}`);
                        if (res.ok) {
                            const data = await res.json();
                            this.competitors = data.competitors || [];
                            this.trackedKeywords = data.trackedKeywords || [];
                        }
                    } catch (e) {
                        console.error('Failed to fetch SEO radar data:', e);
                    } finally {
                        this.loadingSeo = false;
                    }
                },

                async fetchReports() {
                    if (!this.profileId) return;
                    try {
                        const res = await fetch(`/api/v1/reports?locationId=${this.profileId}`);
                        const data = await res.json();
                        if (data.success) {
                            this.reports = data.reports;
                        }
                    } catch (e) {
                        console.error('Failed to fetch reports', e);
                    }
                },

                async generateManualReport() {
                    if (!this.profileId || !this.orgId) return;
                    this.generatingReport = true;
                    try {
                        const res = await fetch(`/api/v1/reports/generate`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ locationId: this.profileId, organizationId: this.orgId })
                        });
                        const data = await res.json();
                        if (data.success) {
                            await this.fetchReports();
                        } else {
                            alert('Failed to generate report');
                        }
                    } catch (e) {
                        console.error('Error generating report:', e);
                    } finally {
                        this.generatingReport = false;
                    }
                },

                async saveWhiteLabelSettings() {
                    if (!this.orgId) return;
                    try {
                        const res = await fetch(`/api/v1/organizations/${this.orgId}/whitelabel`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(this.whiteLabel)
                        });
                        if (res.ok) {
                            alert('Branding saved!');
                        }
                    } catch (e) {
                        console.error('Error saving branding:', e);
                    }
                },
                
                viewReport(report) {
                    alert('View report feature incoming. Report ID: ' + report.id);
                },

                async addKeyword() {
                    if (!this.profileId || !this.newKeyword.trim()) return;
                    this.loadingSeo = true;
                    try {
                        const res = await fetch('/api/v1/seo/keywords', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ locationId: this.profileId, term: this.newKeyword.trim() })
                        });
                        if (res.ok) {
                            this.newKeyword = '';
                            await this.fetchSeoData();
                        } else {
                            alert('Failed to add keyword');
                        }
                    } catch (e) {
                        console.error('Add keyword failed', e);
                    } finally {
                        this.loadingSeo = false;
                    }
                },

                async syncRankings() {
                    if (!this.profileId) return;
                    this.loadingSeo = true;
                    try {
                        const res = await fetch(`/api/v1/sync/rankings/${this.profileId}`, { method: 'POST' });
                        if (res.ok) {
                            // Poll after background job completes
                            setTimeout(() => {
                                this.fetchSeoData();
                            }, 2000);
                        } else {
                            alert('Failed to sync rankings');
                            this.loadingSeo = false;
                        }
                    } catch (e) {
                        console.error('Sync rankings failed', e);
                        this.loadingSeo = false;
                    }
                },

                async fetchProfile() {
                    if (!this.profileId) return;
                    try {
                        const res = await fetch(`/api/v1/mock-gbp/locations/${this.profileId}`);
                        if (res.ok) {
                            const data = await res.json();
                            this.actions = data.actions || [];
                            this.score = data.healthScore || 100;
                            this.competitors = data.competitors || [];
                        }
                    } catch (e) {
                        console.error('Failed to fetch profile:', e);
                    }
                },
                
                openTaskModal(taskTitle) {
                    if (taskTitle === 'Zero recent posts' || taskTitle.includes('dominating local search')) {
                        this.currentTab = 'studio';
                        return;
                    }
                    this.activeTask = taskTitle;
                    this.taskInput = '';
                    if (taskTitle === 'Description is missing') {
                        this.taskInput = '';
                    }
                    this.showModal = true;
                },

                async submitTask() {
                    let finalValue = this.taskInput;
                    
                    // Structured Hours Formatting
                    if (this.activeTask === 'Add Business Hours') {
                        if (this.hoursData.days.length === 0) {
                            alert('Please select at least one day.');
                            return;
                        }
                        finalValue = `${this.hoursData.days.join(',')} ${this.hoursData.open} - ${this.hoursData.close}`;
                    } else {
                        if (!this.taskInput) return;
                    }

                    this.isSubmitting = true;
                    try {
                        const response = await fetch(`/api/v1/mock-gbp/locations/${this.profileId}/updates`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ task: this.activeTask, value: finalValue })
                        });
                        if (response.ok) {
                            await this.fetchProfile(); 
                            this.showModal = false;
                            this.taskInput = '';
                        }
                    } catch (error) {
                        console.error('Submit failed:', error);
                    } finally {
                        this.isSubmitting = false;
                    }
                },
                
                async generateDescriptionAI() {
                    if (!this.profileId) return;
                    this.isGeneratingDesc = true;
                    try {
                        const res = await fetch(`/api/v1/mock-gbp/locations/${this.profileId}/generate-description`, {
                            method: 'POST'
                        });
                        if (res.ok) {
                            const data = await res.json();
                            if (data.success && data.description) {
                                this.taskInput = data.description;
                            }
                        } else {
                            alert('Failed to generate description');
                        }
                    } catch(e) {
                        console.error('Failed to generate description', e);
                    } finally {
                        this.isGeneratingDesc = false;
                    }
                },
                
                async fetchPosts() {
                    if (!this.profileId) return;
                    try {
                        const res = await fetch(`/api/v1/posts?locationId=${this.profileId}`);
                        if (res.ok) {
                            const data = await res.json();
                            this.posts = data.posts || [];
                        }
                    } catch (e) {
                        console.error('Fetch posts failed', e);
                    }
                },
                
                async fetchCalendar() {
                    if (!this.profileId) return;
                    try {
                        const res = await fetch(`/api/v1/locations/${this.profileId}/calendar`);
                        if (res.ok) {
                            const data = await res.json();
                            this.calendarPosts = data.posts || [];
                        }
                    } catch (e) {
                        console.error('Fetch calendar failed', e);
                    }
                },
                
                async fetchMetaStatus() {
                    if (!this.profileId) return;
                    try {
                        const res = await fetch(`/api/v1/social/status/${this.profileId}`);
                        if (res.ok) {
                            const data = await res.json();
                            this.metaStatus = data.meta;
                        }
                    } catch (e) {
                        console.error('Fetch meta status failed', e);
                    }
                },
                
                async connectMeta() {
                    if (!this.profileId) return;
                    try {
                        const mockCode = 'mock_auth_code_' + Math.floor(Math.random() * 1000);
                        const res = await fetch(`/api/v1/social/meta/callback?locationId=${this.profileId}&code=${mockCode}`);
                        if (res.ok) {
                            await this.fetchMetaStatus();
                        }
                    } catch (e) {
                        console.error('Connect meta failed', e);
                    }
                },

                async generatePost() {
                    this.generatingPost = true;
                    try {
                        const res = await fetch(`/api/v1/locations/${this.profileId}/posts/generate`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ goalText: this.postGoal })
                        });
                        const data = await res.json();
                        if (res.ok && data.success) {
                            await this.fetchPosts();
                            this.postGoal = '';
                        } else {
                            alert('Failed to generate post: ' + (data.error || 'Unknown error'));
                        }
                    } catch (e) {
                        console.error('Generate post failed', e);
                    } finally {
                        this.generatingPost = false;
                    }
                },
                
                async publishPost(post) {
                    try {
                        const res = await fetch(`/api/v1/posts/${post.id}/publish`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ textContent: post.textContent })
                        });
                        if (res.ok) {
                            await this.fetchPosts();
                        } else {
                            alert('Failed to publish post');
                        }
                    } catch (e) {
                        console.error('Publish failed', e);
                    }
                },
                
                async schedulePost(post, channels = ['GBP']) {
                    if (!post.scheduleDate) {
                        alert('Please select a date and time to schedule.');
                        return;
                    }
                    try {
                        const res = await fetch(`/api/v1/posts/${post.id}/schedule`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ 
                                scheduledFor: post.scheduleDate, 
                                textContent: post.textContent,
                                channels: JSON.stringify(channels)
                            })
                        });
                        if (res.ok) {
                            await this.fetchPosts();
                            // Push an action to the dashboard
                            this.actions.unshift({
                                id: Date.now(),
                                title: 'Post Scheduled',
                                description: `A post has been scheduled for ${new Date(post.scheduleDate).toLocaleString()}`,
                                impact: 'Medium',
                                locationId: this.profileId
                            });
                        } else {
                            alert('Failed to schedule post');
                        }
                    } catch (e) {
                        console.error('Schedule failed', e);
                    }
                },
                
                async fetchReviews() {
                    if (!this.profileId) return;
                    try {
                        const res = await fetch(`/api/v1/reviews?locationId=${this.profileId}`);
                        if (res.ok) {
                            const data = await res.json();
                            // Keep any local drafts if they are actively being generated
                            this.reviews = data.reviews.map(newRev => {
                                const existing = this.reviews.find(r => r.id === newRev.id);
                                return {
                                    ...newRev,
                                    draft: existing ? existing.draft : ''
                                };
                            });
                        }
                    } catch (e) {
                        console.error('Fetch reviews failed', e);
                    }
                },
                
                async syncReviews() {
                    if (!this.profileId) return;
                    this.isSyncing = true;
                    try {
                        const res = await fetch(`/api/v1/sync/reviews/${this.profileId}`, { method: 'POST' });
                        if (res.status === 202) {
                            // UI non-blocking feedback. Auto-poll will fetch the updated reviews shortly.
                        }
                    } catch (e) {
                        console.error('Trigger sync failed', e);
                    } finally {
                        setTimeout(() => { this.isSyncing = false; }, 2000); // Visual feedback
                    }
                },
                
                async generateAiReply(reviewId) {
                    this.generatingReply[reviewId] = true;
                    try {
                        const res = await fetch(`/api/v1/reviews/${reviewId}/generate`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({})
                        });
                        const data = await res.json();
                        if (res.ok && data.success) {
                            const reviewIndex = this.reviews.findIndex(r => r.id === reviewId);
                            if (reviewIndex !== -1) {
                                this.reviews[reviewIndex].aiSuggestedReply = data.aiSuggestedReply;
                            }
                        } else {
                            alert('Failed to generate AI reply: ' + (data.error || 'Unknown error'));
                        }
                    } catch (e) {
                        console.error('Generate reply failed', e);
                        alert('Error generating reply.');
                    } finally {
                        this.generatingReply[reviewId] = false;
                    }
                },
                
                async publishAiReply(reviewId, replyText) {
                    this.publishingReply[reviewId] = true;
                    try {
                        const res = await fetch(`/api/v1/reviews/${reviewId}/publish`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ replyText })
                        });
                        const data = await res.json();
                        if (res.ok && data.success) {
                            const reviewIndex = this.reviews.findIndex(r => r.id === reviewId);
                            if (reviewIndex !== -1) {
                                this.reviews[reviewIndex].publishedReply = data.review.publishedReply;
                            }
                        } else {
                            alert('Failed to publish reply: ' + (data.error || 'Unknown error'));
                        }
                    } catch (e) {
                        console.error('Publish reply failed', e);
                        alert('Error publishing reply.');
                    } finally {
                        this.publishingReply[reviewId] = false;
                    }
                },
                
                async resetProfileData() {
                    if (!confirm("Are you sure you want to reset all business data? This cannot be undone.")) return;
                    
                    this.isResetting = true;
                    try {
                        const res = await fetch(`/api/v1/mock-gbp/locations/${this.profileId}/reset`, {
                            method: 'POST'
                        });
                        if (res.ok) {
                            await this.fetchLocations();
                            if (this.locations.length > 0) {
                                this.profileId = this.locations[0].id;
                                await this.switchTenant();
                            } else {
                                this.profileId = null;
                            }
                            this.currentTab = 'home';
                        } else {
                            alert("Failed to reset data.");
                        }
                    } catch (e) {
                        console.error('Reset failed', e);
                        alert("An error occurred while resetting.");
                    } finally {
                        this.isResetting = false;
                    }
                },

                async exportBackupData() {
                    this.isExporting = true;
                    try {
                        // Create a temporary link element to trigger the download
                        const link = document.createElement('a');
                        link.href = '/api/v1/export/backup';
                        link.download = 'all-in-one-marketing-backup.zip';
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                        
                        // Fake delay just to show the UI state
                        await new Promise(resolve => setTimeout(resolve, 1500));
                    } catch (e) {
                        console.error('Export failed', e);
                        alert("Failed to export backup data.");
                    } finally {
                        this.isExporting = false;
                    }
                },
                
                async simulateTraffic() {
                    if (!confirm("This will inject 15 mock reviews. Continue?")) return;
                    this.isSimulating = true;
                    try {
                        const targetId = this.profileId || 'fallback';
                        const res = await fetch(`/api/v1/mock-gbp/locations/${targetId}/simulate-traffic`, {
                            method: 'POST'
                        });
                        if (res.ok) {
                            const data = await res.json();
                            if (data.fallbackCreated) {
                                await this.fetchLocations();
                                this.profileId = data.locationId;
                                await this.switchTenant();
                            } else {
                                this.fetchReviews();
                                this.fetchAnalytics();
                            }
                            alert('Simulation triggered successfully! Reviews are pouring in.');
                        } else {
                            const data = await res.json();
                            alert(data.error || "Simulation failed.");
                        }
                    } catch(e) {
                        console.error('Simulation error', e);
                        alert("An error occurred during simulation.");
                    } finally {
                        this.isSimulating = false;
                    }
                },

                async createInitialProfile() {
                    this.isCreatingProfile = true;
                    try {
                        const res = await fetch('/api/v1/mock-gbp/locations', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                name: this.newProfileName,
                                categories: this.newProfileCategory
                            })
                        });
                        const data = await res.json();
                        if (res.ok) {
                            this.locations = [data.location];
                            this.profileId = data.location.id;
                            this.newProfileName = '';
                            this.newProfileCategory = '';
                            await this.loadApp();
                        } else {
                            alert(data.error || "Failed to create profile.");
                        }
                    } catch(e) {
                        console.error("Create profile error:", e);
                        alert("An error occurred.");
                    } finally {
                        this.isCreatingProfile = false;
                    }
                }
            }
        }
    </script>
    </div> <!-- END AUTHENTICATED APP CONTAINER -->

    <!-- ONBOARDING WIZARD (SHOWN WHEN NO LOCATIONS) -->
    <div x-show="isLoggedIn && locations.length === 0" x-cloak class="fixed inset-0 z-[100] flex flex-col items-center justify-center p-6 bg-slate-950">
        <div class="absolute inset-0 bg-gradient-to-br from-indigo-900/20 to-slate-900/40 pointer-events-none"></div>
        <div class="absolute top-0 right-0 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl -mr-20 -mt-20 pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-96 h-96 bg-purple-600/10 rounded-full blur-3xl -ml-20 -mb-20 pointer-events-none"></div>
        
        <div class="w-full max-w-lg bg-slate-900/80 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl relative overflow-hidden z-10">
            <h1 class="text-2xl font-bold text-white mb-2 font-['Plus_Jakarta_Sans']">Initialize Growth OS</h1>
            <p class="text-sm text-slate-400 mb-8">Create your first business profile to get started.</p>
            
            <form @submit.prevent="createInitialProfile()" class="space-y-5">
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5 pl-1">Business Name</label>
                    <input type="text" x-model="newProfileName" required class="w-full bg-black/50 border border-slate-700/50 rounded-xl text-slate-200 px-4 py-3 text-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 focus:outline-none transition-all placeholder-slate-600 font-['Plus_Jakarta_Sans']" placeholder="e.g. Client A - Dental Clinic">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5 pl-1">Business Category / Location</label>
                    <input type="text" x-model="newProfileCategory" required class="w-full bg-black/50 border border-slate-700/50 rounded-xl text-slate-200 px-4 py-3 text-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 focus:outline-none transition-all placeholder-slate-600 font-['Plus_Jakarta_Sans']" placeholder="e.g. Dentist in New York">
                </div>
                
                <button type="submit" :disabled="isCreatingProfile" class="w-full bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-500 hover:to-purple-500 text-white py-3.5 rounded-xl font-bold text-sm transition-all shadow-lg shadow-blue-500/25 flex items-center justify-center gap-2 mt-4 font-['Plus_Jakarta_Sans']">
                    <span x-show="!isCreatingProfile">Create Profile & Initialize Growth OS</span>
                    <span x-show="isCreatingProfile" class="flex items-center gap-2">
                        <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        Creating...
                    </span>
                </button>
            </form>
        </div>
    </div>
</body>
