                            <span x-show="post.status === 'Scheduled'" class="ml-auto text-xs bg-blue-500/20 text-blue-400 px-3 py-1 rounded-full font-bold uppercase tracking-wider border border-blue-500/20">Scheduled</span>
                            <span x-show="post.status === 'DRAFT'" class="ml-auto text-xs bg-slate-500/20 text-slate-400 px-3 py-1 rounded-full font-bold uppercase tracking-wider border border-slate-500/20">Draft</span>
