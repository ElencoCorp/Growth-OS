            <button @click="currentTab = 'reviews'; fetchReviews()" :class="currentTab === 'reviews' ? 'text-blue-400' : 'text-slate-500 hover:text-slate-300'" class="flex flex-col items-center justify-center w-full h-full transition-colors relative">
                <div x-show="currentTab === 'reviews'" class="absolute top-0 w-8 h-0.5 bg-blue-500 rounded-b-full shadow-[0_0_8px_rgba(59,130,246,0.8)]"></div>
                <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
                <span class="text-[10px] font-bold tracking-wide">Reviews</span>
