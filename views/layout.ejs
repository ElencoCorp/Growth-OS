            <button @click="currentTab = 'reports'; fetchReports()" :class="currentTab === 'reports' ? 'text-purple-400' : 'text-slate-500 hover:text-slate-300'" class="flex flex-col items-center justify-center w-full h-full transition-colors relative">
                <div x-show="currentTab === 'reports'" class="absolute top-0 w-8 h-0.5 bg-purple-500 rounded-b-full shadow-[0_0_8px_rgba(168,85,247,0.8)]"></div>
                <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                <span class="text-[10px] font-bold tracking-wide">Reports</span>
