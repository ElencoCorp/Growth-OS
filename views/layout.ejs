                    <svg class="w-16 h-16 text-slate-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    <h3 class="text-lg font-bold text-slate-300 mb-1">No Posts Scheduled</h3>
                    <p class="text-sm text-slate-500 max-w-sm">Head over to the AI Studio to generate and schedule your first post.</p>
                </div>
            </template>
        </div>

        <!-- Analytics Content -->
        <div x-show="currentTab === 'analytics'" style="display: none;" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-bold text-slate-100 flex items-center gap-2">
                    <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                    Performance Insights
                </h2>
                <button @click="syncInsights()" :disabled="loadingAnalytics" class="bg-indigo-600/50 hover:bg-indigo-600 text-white px-4 py-2 rounded-xl text-xs font-bold transition-all flex items-center gap-2 border border-indigo-500/30">
                    <svg class="w-4 h-4" :class="{'animate-spin': loadingAnalytics}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                    Sync
                </button>
            </div>
            
            <!-- Executive Summary -->
            <div class="bg-indigo-900/20 backdrop-blur-md rounded-2xl shadow-xl border border-indigo-500/30 p-5 mb-5 relative overflow-hidden">
                <div class="absolute -top-10 -right-10 w-32 h-32 bg-indigo-500/20 rounded-full blur-3xl"></div>
                <div class="flex items-center gap-2 mb-3 relative z-10">
                    <div class="w-6 h-6 rounded-full bg-indigo-500/30 flex items-center justify-center border border-indigo-400/50">
                        <svg class="w-3.5 h-3.5 text-indigo-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L1 21h22M12 6l7.5 13h-15M11 10h2v4h-2M11 16h2v2h-2"></path></svg>
                    </div>
                    <h3 class="text-sm font-bold text-indigo-300 uppercase tracking-wider">AI Executive Summary</h3>
                </div>
                <div class="relative z-10">
                    <template x-if="loadingAnalytics">
                        <div class="flex items-center gap-2 text-indigo-400/70 text-sm py-2">
                            <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                            Compiling strategic insights...
                        </div>
