                <template x-for="post in posts" :key="post.id">
                    <div class="bg-black/20 backdrop-blur-sm rounded-2xl border border-white/10 p-6 flex flex-col gap-4 transition-all hover:bg-black/30 shadow-xl">
                        
                        <div class="flex items-center gap-2 mb-2">
