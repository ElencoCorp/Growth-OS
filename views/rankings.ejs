<div class="max-w-[1440px] mx-auto px-6 lg:px-8 py-8" id="main-content" x-data="rankingsMatrix()">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Local SEO Rankings</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Track your Google Maps and local search keyword positions.</p>
    </div>

    <!-- Top Card: Visual Grid Representation -->
    <div class="bg-white dark:bg-[#111827] rounded-3xl border border-slate-200/80 dark:border-[#1F2937] p-8 mb-8 shadow-sm relative overflow-hidden">
        <!-- Abstract Map Grid Background -->
        <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, currentColor 1px, transparent 0); background-size: 32px 32px;"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
            <div class="flex-1">
                <div class="inline-flex items-center gap-2 px-3 py-1 bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 rounded-lg text-sm font-bold tracking-wide uppercase mb-4">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                    Live Grid Telemetry
                </div>
                <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Local Search Map Matrix</h2>
                <p class="text-slate-500 dark:text-slate-400 max-w-lg">Monitoring keyword spread across 137 square kilometers of localized search surface area.</p>
            </div>
            
            <div class="grid grid-cols-2 gap-4 w-full md:w-auto">
                <div class="bg-slate-50 dark:bg-[#1F2937]/50 border border-slate-100 dark:border-slate-700/50 p-4 rounded-2xl flex flex-col items-center justify-center min-w-[140px]">
                    <span class="text-3xl font-black text-emerald-500 mb-1" x-text="keywords.filter(k => k.position >= 1 && k.position <= 3).length"></span>
                    <span class="text-xs font-bold text-slate-500 uppercase tracking-wider">Top 3 Spots</span>
                </div>
                <div class="bg-slate-50 dark:bg-[#1F2937]/50 border border-slate-100 dark:border-slate-700/50 p-4 rounded-2xl flex flex-col items-center justify-center min-w-[140px]">
                    <span class="text-3xl font-black text-blue-500 mb-1" x-text="keywords.filter(k => k.position >= 4 && k.position <= 10).length"></span>
                    <span class="text-xs font-bold text-slate-500 uppercase tracking-wider">First Page</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Matrix: Keyword Table -->
    <div class="bg-white dark:bg-[#111827] rounded-2xl border border-slate-200/80 dark:border-[#1F2937] overflow-hidden shadow-sm relative min-h-[300px]">
        
        <!-- Loading State -->
        <div x-show="isLoading" class="absolute inset-0 bg-white/80 dark:bg-[#111827]/80 backdrop-blur-sm flex flex-col items-center justify-center z-20">
            <div class="w-10 h-10 border-4 border-blue-500 rounded-full border-t-transparent animate-spin mb-4"></div>
            <p class="text-sm font-semibold text-slate-600 dark:text-slate-400 animate-pulse">Syncing localized matrix...</p>
        </div>

        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 dark:bg-[#1F2937]/50 border-b border-slate-200 dark:border-slate-700">
                    <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider w-2/5">Target Keyword</th>
                    <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider text-center">Map Position</th>
                    <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider text-center">30-Day Trend</th>
                    <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                <template x-for="keyword in keywords" :key="keyword.id">
                    <tr class="border-b border-slate-100 dark:border-slate-800/50 hover:bg-slate-50/50 dark:hover:bg-[#1F2937]/20 transition-colors">
                        <td class="py-4 px-6">
                            <span class="text-sm font-bold text-slate-900 dark:text-white" x-text="keyword.keyword"></span>
                        </td>
                        <td class="py-4 px-6 text-center">
                            <span class="inline-flex items-center justify-center w-8 h-8 rounded-full text-sm font-black"
                                :class="keyword.position === 0 ? 'bg-slate-100 text-slate-400 dark:bg-slate-800 dark:text-slate-500' : 'bg-slate-900 text-white dark:bg-white dark:text-slate-900'"
                                x-text="keyword.position === 0 ? '-' : '#' + keyword.position">
                            </span>
                        </td>
                        <td class="py-4 px-6 text-center">
                            <template x-if="keyword.trend > 0">
                                <span class="inline-flex items-center gap-1 text-sm font-bold text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-500/10 px-2.5 py-1 rounded-lg">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg>
                                    +<span x-text="keyword.trend"></span> positions
                                </span>
                            </template>
                            <template x-if="keyword.trend < 0">
                                <span class="inline-flex items-center gap-1 text-sm font-bold text-rose-600 dark:text-rose-400 bg-rose-50 dark:bg-rose-500/10 px-2.5 py-1 rounded-lg">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
                                    <span x-text="keyword.trend"></span> positions
                                </span>
                            </template>
                            <template x-if="keyword.trend === 0">
                                <span class="inline-flex items-center gap-1 text-sm font-bold text-slate-500 bg-slate-100 dark:bg-slate-800 px-2.5 py-1 rounded-lg">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 12h14"></path></svg>
                                    Stable
                                </span>
                            </template>
                        </td>
                        <td class="py-4 px-6 text-right">
                            <button 
                                @click="openOptimizationSheet(keyword)"
                                class="inline-flex items-center gap-2 text-xs font-bold bg-blue-50 text-blue-600 hover:bg-blue-100 dark:bg-blue-500/10 dark:text-blue-400 dark:hover:bg-blue-500/20 px-4 py-2 rounded-xl transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                                Optimize Profile for This Keyword
                            </button>
                        </td>
                    </tr>
                </template>
                <tr x-show="!isLoading && keywords.length === 0">
                    <td colspan="4" class="py-12 text-center">
                        <p class="text-slate-500 dark:text-slate-400">No tracking data established. Please configure radar keywords.</p>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Optimization Slide-Over Panel -->
    <div x-show="isOptimizationOpen" 
         style="display: none;"
         class="fixed inset-0 z-50 overflow-hidden" 
         aria-labelledby="slide-over-title" 
         role="dialog" 
         aria-modal="true">
        
        <!-- Backdrop -->
        <div x-show="isOptimizationOpen" 
             x-transition:enter="ease-in-out duration-500" 
             x-transition:enter-start="opacity-0" 
             x-transition:enter-end="opacity-100" 
             x-transition:leave="ease-in-out duration-500" 
             x-transition:leave-start="opacity-100" 
             x-transition:leave-end="opacity-0" 
             class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm transition-opacity" 
             @click="closeOptimizationSheet()"></div>

        <div class="fixed inset-y-0 right-0 max-w-md w-full flex">
            <!-- Slide-over -->
            <div x-show="isOptimizationOpen" 
                 x-transition:enter="transform transition ease-in-out duration-500 sm:duration-700" 
                 x-transition:enter-start="translate-x-full" 
                 x-transition:enter-end="translate-x-0" 
                 x-transition:leave="transform transition ease-in-out duration-500 sm:duration-700" 
                 x-transition:leave-start="translate-x-0" 
                 x-transition:leave-end="translate-x-full" 
                 class="w-full h-full bg-white dark:bg-[#111827] shadow-2xl flex flex-col border-l border-slate-200 dark:border-slate-800">
                
                <div class="px-6 py-6 border-b border-slate-100 dark:border-slate-800 flex items-start justify-between">
                    <div>
                        <div class="flex items-center gap-2 text-blue-600 dark:text-blue-400 mb-1">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                            <span class="text-xs font-bold uppercase tracking-wider">AI Optimization Engine</span>
                        </div>
                        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Rank Improvement Strategy</h2>
                    </div>
                    <button @click="closeOptimizationSheet()" class="text-slate-400 hover:text-slate-500 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>

                <div class="p-6 flex-1 overflow-y-auto">
                    <div class="bg-slate-50 dark:bg-slate-800/50 rounded-xl p-4 mb-6 border border-slate-200 dark:border-slate-700">
                        <p class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-1">Target Keyword</p>
                        <p class="text-lg font-bold text-slate-900 dark:text-white" x-text="activeKeyword?.keyword"></p>
                        
                        <div class="flex items-center gap-4 mt-3">
                            <div>
                                <p class="text-[10px] text-slate-500 uppercase tracking-widest font-bold">Current Pos</p>
                                <p class="text-sm font-black text-slate-700 dark:text-slate-300" x-text="activeKeyword?.position === 0 ? '-' : '#' + activeKeyword?.position"></p>
                            </div>
                            <div>
                                <p class="text-[10px] text-slate-500 uppercase tracking-widest font-bold">Trend</p>
                                <p class="text-sm font-black text-emerald-600" x-show="activeKeyword?.trend > 0" x-text="'+' + activeKeyword?.trend"></p>
                                <p class="text-sm font-black text-rose-600" x-show="activeKeyword?.trend < 0" x-text="activeKeyword?.trend"></p>
                                <p class="text-sm font-black text-slate-500" x-show="activeKeyword?.trend === 0">Stable</p>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <h3 class="text-sm font-bold text-slate-900 dark:text-white">Recommended Actions</h3>
                        
                        <!-- Action 1 -->
                        <div class="flex gap-4 p-4 rounded-xl border border-blue-100 dark:border-blue-900/30 bg-white dark:bg-[#1F2937]">
                            <div class="w-8 h-8 rounded-full bg-blue-50 dark:bg-blue-500/10 flex items-center justify-center shrink-0 text-blue-600">
                                <span class="font-bold">1</span>
                            </div>
                            <div>
                                <h4 class="text-sm font-bold text-slate-900 dark:text-white">Generate Local Update Post</h4>
                                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Publish a Google Business post focused on this keyword to increase local relevance signals.</p>
                                <button class="mt-3 text-xs font-semibold bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg transition-colors shadow-sm w-full">Draft AI Post Now</button>
                            </div>
                        </div>
                        
                        <!-- Action 2 -->
                        <div class="flex gap-4 p-4 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-[#1F2937]">
                            <div class="w-8 h-8 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center shrink-0 text-slate-600 dark:text-slate-400">
                                <span class="font-bold">2</span>
                            </div>
                            <div>
                                <h4 class="text-sm font-bold text-slate-900 dark:text-white">Review Request Campaign</h4>
                                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Send an automated SMS blast to recent customers asking for reviews mentioning this service.</p>
                                <button class="mt-3 text-xs font-semibold bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 px-4 py-2 rounded-lg transition-colors w-full">Trigger Campaign</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function rankingsMatrix() {
    return {
        keywords: [],
        isLoading: false,
        isOptimizationOpen: false,
        activeKeyword: null,

        init() {
            this.$watch('activeLocation', () => {
                this.fetchRankings();
            });
            
            if (this.activeLocation && this.activeLocation.id) {
                this.fetchRankings();
            }
        },

        async fetchRankings() {
            if (!this.activeLocation || !this.activeLocation.id) return;
            this.isLoading = true;
            try {
                const response = await fetch(`/api/v1/rankings?locationId=${this.activeLocation.id}`);
                const data = await response.json();
                if (data.success) {
                    this.keywords = data.keywords;
                }
            } catch (error) {
                console.error("Failed to fetch local rankings:", error);
            } finally {
                setTimeout(() => this.isLoading = false, 400);
            }
        },
        
        openOptimizationSheet(keyword) {
            this.activeKeyword = keyword;
            this.isOptimizationOpen = true;
        },
        
        closeOptimizationSheet() {
            this.isOptimizationOpen = false;
            // Delay clearing data so animation is smooth
            setTimeout(() => {
                this.activeKeyword = null;
            }, 500);
        }
    }
}
</script>
