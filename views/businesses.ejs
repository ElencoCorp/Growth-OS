<div class="max-w-[1440px] mx-auto px-6 lg:px-8 py-8" id="main-content">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Business Locations</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Manage all your physical storefronts and Google Business Profiles.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% if (businesses && businesses.length > 0) { %>
            <% businesses.forEach(function(business) { %>
                <div class="bg-white dark:bg-[#111827] rounded-2xl border border-slate-200/80 dark:border-[#1F2937] p-6 shadow-sm flex flex-col gap-4">
                    <div>
                        <h3 class="text-lg font-bold text-slate-900 dark:text-white"><%= business.name %></h3>
                        <p class="text-xs font-medium text-slate-500 mt-1">Org: <%= business.organization ? business.organization.name : 'Unknown' %></p>
                    </div>
                    <div class="text-sm text-slate-600 dark:text-slate-300 flex-1">
                        <p><strong>Address:</strong> <%= business.address || 'N/A' %></p>
                        <p><strong>Timezone:</strong> <%= business.timezone || 'UTC' %></p>
                    </div>
                    <div class="pt-4 border-t border-slate-100 dark:border-[#1F2937] flex justify-between items-center">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-[10px] font-bold tracking-wider uppercase <%= business.status === 'ACTIVE' ? 'bg-emerald-50 text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400' : 'bg-amber-50 text-amber-600 dark:bg-amber-500/10 dark:text-amber-400' %>">
                            <%= business.status || 'PENDING' %>
                        </span>
                        <button class="text-sm font-semibold text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300">Manage</button>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="col-span-full py-12 text-center bg-slate-50 dark:bg-[#1F2937]/30 rounded-2xl border border-dashed border-slate-300 dark:border-slate-700">
                <p class="text-slate-500 dark:text-slate-400 font-medium">No business locations found. Connect your first Google Business Profile.</p>
            </div>
        <% } %>
    </div>
</div>
