<div class="max-w-[1440px] mx-auto px-6 lg:px-8 py-8" id="main-content" x-data="businessesGrid()">
    
    <!-- HEADER -->
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Business Locations</h1>
            <p class="text-slate-500 dark:text-slate-400 mt-1">Manage all your physical storefronts and Google Business Profiles.</p>
        </div>
        <div class="flex items-center gap-3">
            <a href="/api/v1/auth/google" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-white dark:bg-[#111827] border border-slate-200 dark:border-[#1F2937] text-sm font-semibold text-slate-700 dark:text-slate-200 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-800 transition-all shadow-sm hover:shadow active:scale-95">
                <svg class="w-4 h-4 text-slate-600 dark:text-slate-400" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                Connect GBP Account
            </a>
            <button class="inline-flex items-center justify-center px-5 py-2.5 bg-blue-600 text-white text-sm font-semibold rounded-xl hover:bg-blue-700 transition-all shadow-md hover:shadow-lg active:scale-95">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Add Location
            </button>
        </div>
    </div>

    <!-- NOTIFICATIONS -->
    <% if (typeof alert !== 'undefined' && alert === 'google_auth_success') { %>
        <div class="mb-6 p-4 rounded-xl bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20 text-emerald-800 dark:text-emerald-400 flex items-center justify-between" x-data="{ show: true }" x-show="show">
            <div class="flex items-center gap-3">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span class="text-sm font-semibold">Google Account Connected successfully! Your locations are syncing.</span>
            </div>
            <button @click="show = false" class="text-emerald-600 hover:text-emerald-800"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
        </div>
    <% } %>

    <!-- DYNAMIC GRID -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        <template x-for="loc in locations" :key="loc.id">
            <div class="bg-white dark:bg-[#111827] rounded-[20px] border border-slate-200/80 dark:border-[#1F2937] p-6 shadow-sm hover:shadow-md transition-all flex flex-col group relative overflow-hidden">
                <!-- Top Actions -->
                <div class="absolute top-4 right-4 flex items-center gap-2">
                    <span class="inline-flex items-center px-2 py-1 rounded-md text-[10px] font-bold tracking-wider uppercase bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400" x-text="loc.organization?.name || 'Unknown Org'"></span>
                </div>

                <!-- Profile Info -->
                <div class="flex items-start gap-4 mb-5">
                    <div class="w-12 h-12 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 flex items-center justify-center shrink-0 font-bold text-lg border border-blue-100 dark:border-blue-800/50" x-text="loc.name.charAt(0)"></div>
                    <div class="pr-12">
                        <h3 class="text-lg font-bold text-slate-900 dark:text-white leading-tight mb-1" x-text="loc.name"></h3>
                        <p class="text-xs text-slate-500 dark:text-slate-400 font-medium" x-text="loc.categories || 'Uncategorized'"></p>
                    </div>
                </div>

                <!-- Stats Row -->
                <div class="grid grid-cols-2 gap-3 mb-6 flex-1">
                    <div class="p-3 rounded-xl bg-slate-50 dark:bg-[#1F2937]/50 border border-slate-100 dark:border-slate-700/50">
                        <p class="text-[10px] uppercase font-bold text-slate-500 mb-1 tracking-wider">Reviews</p>
                        <p class="text-xl font-black text-slate-900 dark:text-white" x-text="loc.reviews ? loc.reviews.length : 0"></p>
                    </div>
                    <div class="p-3 rounded-xl bg-slate-50 dark:bg-[#1F2937]/50 border border-slate-100 dark:border-slate-700/50">
                        <p class="text-[10px] uppercase font-bold text-slate-500 mb-1 tracking-wider">Health Score</p>
                        <div class="flex items-center gap-2">
                            <p class="text-xl font-black text-emerald-600 dark:text-emerald-400" x-text="loc.healthScore || 0"></p>
                            <span class="text-[10px] text-emerald-600 font-bold">/100</span>
                        </div>
                    </div>
                </div>

                <!-- Interactive Operational Row -->
                <div class="pt-4 border-t border-slate-100 dark:border-[#1F2937] flex items-center justify-between">
                    <div>
                        <div class="flex items-center gap-1.5 mb-1">
                            <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                            <span class="text-xs font-semibold text-slate-700 dark:text-slate-300">Google Connected</span>
                        </div>
                        <p class="text-[10px] text-slate-500 font-medium font-mono" x-text="'Sync: ' + formatTime(loc.lastInsightsSync)"></p>
                    </div>
                    
                    <button @click="syncLocation(loc)" 
                            :disabled="loc.isSyncing"
                            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 text-xs font-bold rounded-lg transition-colors disabled:opacity-50">
                        <svg class="w-3 h-3" :class="{'animate-spin text-blue-500': loc.isSyncing}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                        <span x-text="loc.isSyncing ? 'Syncing...' : 'Sync Now'"></span>
                    </button>
                </div>
            </div>
        </template>
        
        <!-- Empty State -->
        <div x-show="locations.length === 0" class="col-span-full py-16 text-center bg-white dark:bg-[#111827] rounded-[20px] border border-dashed border-slate-300 dark:border-slate-700 flex flex-col items-center justify-center">
            <div class="w-16 h-16 rounded-full bg-slate-50 dark:bg-slate-800 flex items-center justify-center mb-4">
                <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">No locations found</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 max-w-sm mb-6">Connect your Google Business Profile account to automatically import and analyze your physical storefronts.</p>
            <a href="/api/v1/auth/google" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-colors shadow-md">
                Connect Google Account
            </a>
        </div>
    </div>
</div>

<script>
function businessesGrid() {
    return {
        locations: <%- JSON.stringify(businesses || []) %>,
        
        init() {
            // Check for alert param
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.has('alert') && urlParams.get('alert') === 'google_auth_success') {
                // We show an Alpine alert block if we want, or use the EJS one
                window.history.replaceState({}, document.title, window.location.pathname);
            }
            
            // Add isSyncing local state
            this.locations = this.locations.map(loc => ({ ...loc, isSyncing: false }));
        },
        
        formatTime(dateStr) {
            if (!dateStr) return 'Never';
            const date = new Date(dateStr);
            const now = new Date();
            const diffInMins = Math.floor((now - date) / (1000 * 60));
            
            if (diffInMins < 1) return 'Just now';
            if (diffInMins < 60) return `${diffInMins}m ago`;
            if (diffInMins < 1440) return `${Math.floor(diffInMins / 60)}h ago`;
            return `${Math.floor(diffInMins / 1440)}d ago`;
        },
        
        async syncLocation(loc) {
            if (loc.isSyncing) return;
            loc.isSyncing = true;
            
            try {
                const response = await fetch(`/api/v1/locations/${loc.id}/sync`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                if (response.ok) {
                    const data = await response.json();
                    if (data.success && data.location) {
                        loc.lastInsightsSync = data.location.lastInsightsSync;
                    }
                }
            } catch (error) {
                console.error('Failed to sync location:', error);
            } finally {
                setTimeout(() => { loc.isSyncing = false; }, 600); // Artificial delay for smooth UX
            }
        }
    }
}
</script>
