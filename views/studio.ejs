<div class="max-w-[1440px] mx-auto px-6 lg:px-8 py-8" id="main-content" x-data="{ campaignGoal: '', tone: 'Professional & Authoritative', keywords: '', topic: '', loading: false, generatedContent: null }">
    <!-- HEADER -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">AI Content Studio</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Generate hyper-localized marketing content for your Google Business Profiles.</p>
    </div>

    <!-- DUAL COLUMN WORKSPACE -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        <!-- LEFT COLUMN: Input Form -->
        <div class="lg:col-span-4 bg-white dark:bg-[#111827] rounded-3xl border border-slate-200/80 dark:border-[#1F2937] p-6 shadow-sm">
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                Campaign Config
            </h3>
            
            <div class="space-y-5">
                <!-- Location Info (Hidden but sent) -->
                <input type="hidden" name="locationId" :value="activeLocation ? activeLocation.id : ''">

                <div>
                    <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">Campaign Goal</label>
                    <select x-model="campaignGoal" required class="w-full bg-slate-50 dark:bg-[#1F2937]/50 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all appearance-none">
                        <option value="" disabled>Select a goal...</option>
                        <option value="Promotional">Promotional / Special Offer</option>
                        <option value="Informational">Informational / Update</option>
                        <option value="Event">Event / Neighborhood Activation</option>
                        <option value="Review Request">Review Request / Testimonial</option>
                    </select>
                </div>
                
                <div>
                    <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">Brand Tone of Voice</label>
                    <select x-model="tone" required class="w-full bg-slate-50 dark:bg-[#1F2937]/50 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all appearance-none">
                        <option value="Professional & Authoritative">Professional & Authoritative</option>
                        <option value="Enthusiastic & Friendly">Enthusiastic & Friendly</option>
                        <option value="Urgent & Action-Oriented">Urgent & Action-Oriented</option>
                        <option value="Trustworthy & Community-Focused">Trustworthy & Community-Focused</option>
                    </select>
                </div>
                
                <div>
                    <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">Target Keywords</label>
                    <input type="text" x-model="keywords" placeholder="e.g. root canal, best dentist, Mumbai" class="w-full bg-slate-50 dark:bg-[#1F2937]/50 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all placeholder:text-slate-400">
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">Topic or Context (Optional)</label>
                    <textarea x-model="topic" rows="3" placeholder="What is this post specifically about?" class="w-full bg-slate-50 dark:bg-[#1F2937]/50 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all placeholder:text-slate-400 resize-none"></textarea>
                </div>
                
                <div class="pt-2">
                    <button type="button" @click="loading = true; fetch('/api/v1/studio/generate', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ goal: campaignGoal, tone: tone, keywords: keywords, topic: topic, locationId: typeof activeLocation !== 'undefined' && activeLocation ? activeLocation.id : '' }) }).then(res => res.json()).then(data => { generatedContent = data; loading = false; })" :disabled="loading || !activeLocation" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-xl transition-all shadow-md hover:shadow-lg disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2">
                        <svg x-show="loading" class="animate-spin h-5 w-5 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        <span x-text="loading ? 'Drafting...' : 'Generate Post'"></span>
                    </button>
                    <p x-show="!activeLocation" class="text-xs text-center text-red-500 mt-3 font-medium">Please select a location from the top bar to generate content.</p>
                </div>
            </div>
        </div>

        <!-- RIGHT COLUMN: Preview Canvas -->
        <div class="lg:col-span-8 bg-white dark:bg-[#111827] rounded-3xl border border-slate-200/80 dark:border-[#1F2937] p-8 shadow-sm min-h-[500px] flex flex-col relative overflow-hidden">
            
            <!-- Default Empty State -->
            <div x-show="!generatedContent && !loading" class="flex-1 flex flex-col items-center justify-center text-center">
                <div class="w-20 h-20 bg-slate-50 dark:bg-slate-800/50 rounded-full flex items-center justify-center mb-4">
                    <svg class="w-10 h-10 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                </div>
                <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-2">Ready to Draft</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400 max-w-sm">Configure your campaign parameters on the left and hit generate to create hyper-optimized local content.</p>
            </div>

            <!-- Loading Pulse State -->
            <div x-show="loading" class="absolute inset-0 bg-white/80 dark:bg-[#111827]/80 backdrop-blur-sm flex flex-col items-center justify-center z-10" style="display: none;">
                <div class="relative w-24 h-24 flex items-center justify-center mb-4">
                    <div class="absolute inset-0 border-4 border-blue-500/20 rounded-full"></div>
                    <div class="absolute inset-0 border-4 border-blue-500 rounded-full border-t-transparent animate-spin"></div>
                    <svg class="w-8 h-8 text-blue-600 dark:text-blue-400 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </div>
                <p class="text-lg font-bold text-slate-900 dark:text-white mb-1">Synthesizing Context...</p>
                <p class="text-sm text-slate-500 dark:text-slate-400">Aligning brand tone and local keywords.</p>
            </div>

            <!-- Generated Content View -->
            <div x-show="!loading && generatedContent" class="flex-1 flex flex-col" style="display: none;">
                <div class="flex items-center justify-between mb-6 pb-6 border-b border-slate-100 dark:border-slate-800">
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-2">
                        <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        Draft Ready
                    </h3>
                    <div class="flex gap-2">
                        <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-xs font-bold rounded-lg tracking-wide uppercase" x-text="campaignGoal"></span>
                    </div>
                </div>

                <!-- Image Preview Box -->
                <div x-show="generatedContent && generatedContent.imageUrl" class="mb-6 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700 bg-slate-100 dark:bg-slate-800 relative h-[250px]">
                    <img :src="generatedContent ? generatedContent.imageUrl : ''" alt="Generated Promo Graphic" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
                    <div class="absolute bottom-4 left-4 right-4 flex items-center justify-between">
                        <span class="text-white text-xs font-bold tracking-wide uppercase bg-black/40 backdrop-blur-md px-2 py-1 rounded-md">AI Generated Asset</span>
                        <button class="text-white hover:text-blue-300 transition-colors p-1 bg-black/40 backdrop-blur-md rounded-md">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                        </button>
                    </div>
                </div>

                <div class="flex-1 mb-4 relative group">
                    <textarea x-model="generatedContent ? generatedContent.bodyText : ''" class="w-full h-full min-h-[150px] bg-slate-50 dark:bg-[#1F2937]/30 border border-slate-100 dark:border-slate-800 rounded-2xl p-5 text-[14px] leading-relaxed text-slate-800 dark:text-slate-200 focus:ring-2 focus:ring-blue-500/20 outline-none resize-none transition-all"></textarea>
                </div>

                <!-- Hashtags block -->
                <div class="mb-6 flex flex-wrap gap-2">
                    <template x-if="generatedContent && generatedContent.hashtags">
                        <template x-for="tag in generatedContent.hashtags.split(' ')" :key="tag">
                            <span x-show="tag" class="px-2.5 py-1 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 text-xs font-bold rounded-lg cursor-pointer hover:bg-blue-100 dark:hover:bg-blue-900/40 transition-colors" x-text="tag"></span>
                        </template>
                    </template>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4 border-t border-slate-100 dark:border-slate-800">
                    <button class="px-4 py-2.5 bg-emerald-50 text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400 font-bold rounded-xl flex items-center justify-center gap-2 text-sm pointer-events-none border border-emerald-100 dark:border-emerald-500/20">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Successfully Queued (48h Autopilot)
                    </button>
                    <button class="px-4 py-2.5 bg-white dark:bg-[#111827] border border-slate-200 dark:border-[#1F2937] text-slate-700 dark:text-slate-300 font-semibold rounded-xl hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors flex items-center justify-center gap-2 text-sm shadow-sm group">
                        <svg class="w-4 h-4 text-slate-400 group-hover:text-blue-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                        Edit Queue Schedule
                    </button>
                </div>
            </div>
            
        </div>
    </div>
</div>
